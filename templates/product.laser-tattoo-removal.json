    "aftercare": {
      "type": "lsc-aftercare",
      "blocks": {
        "step_1": {
          "type": "step",
          "settings": {
            "timeframe": "0–48 Hours",
            "title": "Keep It Covered & Clean",
            "description": "Apply Vaseline to the treated area. Cover with a sterile non-stick dressing if needed. Do not rub or scratch — blistering is normal and part of the healing process."
          }
        },
        "step_2": {
          "type": "step",
          "settings": {
            "timeframe": "Days 2–7",
            "title": "Let It Heal Naturally",
            "description": "Avoid picking or peeling any blistered skin. Apply healing cream 2–3 times daily. Keep out of direct sunlight and avoid swimming or heavy exercise."
          }
        },
        "step_3": {
          "type": "step",
          "settings": {
            "timeframe": "Weeks 2–8",
            "title": "Ink Continues to Fade",
            "description": "Your immune system is actively removing fragmented ink particles — continue to see fading for up to 6–8 weeks post-session. SPF 50+ is essential on the treated area."
          }
        }
      },
      "block_order": [
        "step_1",
        "step_2",
        "step_3"
