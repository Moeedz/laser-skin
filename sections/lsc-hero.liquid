{{ 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Outfit:wght@300;400;500&display=swap' | stylesheet_tag }}

<style>
  :root {
    --gold: #C4A97D;
    --gold-light: #D4BE9A;
    --deep: #1A1714;
  }

  .lsc-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .lsc-hero__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    z-index: 1;
  }

  .lsc-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(26, 23, 20, 0.3), rgba(26, 23, 20, 0.5));
    z-index: 2;
  }

  .lsc-hero__content {
    position: relative;
    z-index: 3;
    text-align: center;
    max-width: 700px;
    padding: 0 1.5rem;
  }

  /* --- Fade-in animation --- */
  @keyframes lscHeroFadeIn {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .lsc-hero__content > * {
    opacity: 0;
    animation: lscHeroFadeIn 0.8s ease-out forwards;
  }

  .lsc-hero__eyebrow   { animation-delay: 0.2s; }
  .lsc-hero__heading    { animation-delay: 0.45s; }
  .lsc-hero__subheading { animation-delay: 0.7s; }
  .lsc-hero__cta        { animation-delay: 0.95s; }
  .lsc-hero__rating     { animation-delay: 1.2s; }

  /* --- Eyebrow --- */
  .lsc-hero__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1.5rem;
    margin-top: 0;
  }

  /* --- Heading --- */
  .lsc-hero__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 300;
    color: #ffffff;
    line-height: 1.15;
    margin-top: 0;
    margin-bottom: 1.2rem;
  }

  /* --- Subheading --- */
  .lsc-hero__subheading {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    margin-top: 0;
    margin-bottom: 2.5rem;
  }

  /* --- CTA Button --- */
  .lsc-hero__cta {
    display: inline-block;
    font-family: 'Outfit', sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background-color: var(--gold);
    color: var(--deep);
    padding: 0.95rem 2.4rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .lsc-hero__cta:hover {
    background-color: var(--gold-light);
  }

  /* --- Rating --- */
  .lsc-hero__rating {
    display: block;
    margin-top: 1.5rem;
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.6);
  }

  /* --- Scroll Indicator --- */
  @keyframes lscScrollPulse {
    0%, 100% {
      opacity: 0.4;
      transform: translateX(-50%) translateY(0);
    }
    50% {
      opacity: 0.8;
      transform: translateX(-50%) translateY(6px);
    }
  }

  .lsc-hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    animation: lscScrollPulse 2s ease-in-out infinite;
  }

  .lsc-hero__scroll svg {
    width: 22px;
    height: 22px;
    stroke: rgba(255, 255, 255, 0.5);
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
</style>

<section class="lsc-hero">
  {% if section.settings.image != blank %}
    <div
      class="lsc-hero__bg"
      style="background-image: url('{{ section.settings.image | image_url: width: 2400 }}');"
    ></div>
  {% else %}
    <div
      class="lsc-hero__bg"
      style="background-color: #2a2520;"
    ></div>
  {% endif %}

  <div class="lsc-hero__overlay"></div>

  <div class="lsc-hero__content">
    <p class="lsc-hero__eyebrow">LASER SKIN CLINICS &middot; WOLVERHAMPTON</p>

    <h1 class="lsc-hero__heading">{{ section.settings.heading }}</h1>

    <p class="lsc-hero__subheading">{{ section.settings.subheading }}</p>

    <a href="{{ section.settings.cta_link }}" class="lsc-hero__cta">
      {{ section.settings.cta_text }}
    </a>

    <span class="lsc-hero__rating">Google &#9733; 4.9/5 &mdash; Recommended by 246+ clients</span>
  </div>

  <div class="lsc-hero__scroll" aria-hidden="true">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clearer Skin. Lasting Results. Clinically Delivered."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Consultation-led treatments and regenerative therapies using advanced laser and medical technology."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Book Your Complimentary Skin Assessment"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
