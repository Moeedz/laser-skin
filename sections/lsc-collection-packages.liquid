          <a href="/products/the-lift-heal-glow-supreme-package" class="lsc-pkg__card-btn--view">View Package</a>
          {%- capture pkg3_msg -%}Hi! I would like to book the Lift Heal and Glow package please.{%- endcapture -%}
          <a
            href="https://wa.me/447340485665?text={{ pkg3_msg | url_encode }}"
            class="lsc-pkg__card-btn"
