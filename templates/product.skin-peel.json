    "ss_simple_faq_jiYFWj": {
      "type": "ss-simple-faq",
      "blocks": {
        "text_Dpx4Qh": {
          "type": "text",
          "settings": {
            "question": "What is the difference between ablative and non-ablative CO2 laser?",
            "answer": "<p>Ablative resurfacing removes damaged cells on the surface, while non-ablative treatment works deeper to remodel collagen without breaking the skin barrier. </p><p></p>"
          }
        },
        "text_zWknmA": {
          "type": "text",
          "disabled": true,
          "settings": {
            "question": "What is your cancellation policy?",
            "answer": "<p>Cancellations up to 24 hours before your appointment will receive a full refund or can be rescheduled.<br/><br/>Any cancellations on the day can be rescheduled but will not be refunded.</p>"
          }
        },
        "text_AYYwGh": {
          "type": "text",
          "settings": {
            "question": "I would like to speak to someone before I book my treatment, how is best to do this?",
            "answer": "<p>If you would like to speak to someone please do one of the below.<br/><br/>- Use the enquiry button.<br/><br/>- Contact us via email at info@laserskinclinics.co.uk<br/><br/>- Call us during opening hours on 01902 256667<br/><br/>- Send us a WhatsApp by clicking the WhatsApp button on the website.</p>"
          }
        },
        "text_Najw7q": {
          "type": "text",
          "settings": {
            "question": "Do I need to book a consultation before my first session?",
            "answer": "<p>No you don't your consultation is done on the day of your treatment.</p>"
          }
        },
        "text_iapnQM": {
          "type": "text",
          "settings": {
            "question": "What happens if you determine the treatment is not for me?",
            "answer": "<p>You will be issued a full refund.</p>"
          }
        },
        "text_JMUbWR": {
          "type": "text",
          "settings": {
            "question": "Who is CO2 Laser Resurfacing suitable for?",
            "answer": "<p>It is suitable for those looking to address fine lines, sun damage, scarring, or uneven texture.<br/><br/>Ablative resurfacing is best for moderate to advanced skin concerns, while non-ablative suits those seeking a gentler option with less downtime.</p>"
          }
        },
        "text_UiGdVT": {
          "type": "text",
          "settings": {
            "question": "Is there any downtime?",
            "answer": "<p>Ablative CO2 resurfacing typically involves 5 to 7 days of recovery, while non-ablative treatments have little to no downtime.</p><p>Your practitioner will advise on post-treatment care and the expected healing period.</p>"
          }
        },
        "text_P8rQpD": {
          "type": "text",
          "settings": {
            "question": "When will I see results?",
            "answer": "<p>You will begin to notice improvements within 4-6 weeks.<br/><br/>Collagen production continues to increase for several months, enhancing firmness and clarity over time.</p>"
          }
        },
        "text_XUDYHP": {
          "type": "text",
          "settings": {
            "question": "How long do results last?",
            "answer": "<p>Results can last several years depending on skin type, age, and lifestyle.<br/><br/>Annual maintenance treatments and good sun protection help prolong results.</p>"
          }
        },
        "text_nPeQJz": {
          "type": "text",
          "settings": {
            "question": "How many sessions do I need?",
            "answer": "<p>Most clients see significant improvement after a single session.<br/><br/>However, a course of 3-6 treatments may be recommended for deeper concerns.</p>"
          }
        }
      },
