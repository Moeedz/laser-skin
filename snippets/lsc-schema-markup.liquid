{% comment %}
  Snippet: lsc-schema-markup.liquid
  JSON-LD structured data for SEO and rich results.
  Include once in theme.liquid: {% render 'lsc-schema-markup' %}
{% endcomment %}

{%- comment -%} ── LocalBusiness + MedicalBusiness (homepage only) ── {%- endcomment -%}
{%- if template == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "MedicalBusiness"],
  "name": "Laser Skin Clinics",
  "url": "https://laserskinclinics.co.uk",
  "telephone": "01902 256 667",
  "email": "info@laserskinclinics.co.uk",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "4 Perton Farm Barns, Jenny Walkers Lane",
    "addressLocality": "Wolverhampton",
    "postalCode": "WV6 7HB",
    "addressCountry": "GB"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "52.6132",
    "longitude": "-2.1903"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Tuesday", "Wednesday", "Friday"],
      "opens": "10:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "10:00",
      "closes": "16:00"
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "246",
    "bestRating": "5"
  },
  "priceRange": "££",
  "areaServed": ["Wolverhampton", "Perton", "Tettenhall", "South Staffordshire", "West Midlands"],
  "image": "{{ 'logo.png' | asset_url }}"
}
</script>
{%- endif -%}

{%- comment -%} ── Service schema (product pages only) ── {%- endcomment -%}
{%- if template contains 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 200 | json }},
  "provider": {
    "@type": "MedicalBusiness",
    "name": "Laser Skin Clinics",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "4 Perton Farm Barns, Jenny Walkers Lane",
      "addressLocality": "Wolverhampton",
      "postalCode": "WV6 7HB",
      "addressCountry": "GB"
    }
  },
  "areaServed": "Wolverhampton",
  "availableChannel": {
    "@type": "ServiceChannel",
    "serviceType": "In person"
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "GBP",
    "availability": "https://schema.org/InStock"
    {%- if product.metafields.custom.price_from != blank -%}
    ,"price": {{ product.metafields.custom.price_from | remove: '£' | remove: ',' | json }}
    ,"priceValidUntil": "{{ 'now' | date: '%Y' | plus: 1 }}-12-31"
    {%- elsif product.price > 0 -%}
    ,"price": {{ product.price | money_without_currency | json }}
    ,"priceValidUntil": "{{ 'now' | date: '%Y' | plus: 1 }}-12-31"
    {%- endif -%}
  }
}
</script>
{%- endif -%}

{%- comment -%} ── BreadcrumbList removed — handled by microdata-schema.liquid to avoid duplicates ── {%- endcomment -%}
