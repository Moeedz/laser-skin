    margin: 0 auto 2rem;
    position: relative;
    z-index: 2;
  }
  .lsc-ct__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 1rem 2.2rem;
    background: var(--gold, #C4A97D);
    color: var(--deep, #1A1714);
    text-decoration: none;
    transition: all 0.4s;
    position: relative;
    z-index: 2;
  }
  .lsc-ct__cta-btn:hover {
    background: var(--gold-light, #D4BE9A);
    transform: translateY(-1px);
  }

  /* ── Responsive ── */
  @media screen and (max-width: 1024px) {
    .lsc-ct__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (max-width: 768px) {
    .lsc-ct__header {
      padding: 3.5rem 5% 2.5rem;
    }
