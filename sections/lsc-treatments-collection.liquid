</section>

<!-- ════════════════════════════════════════════════
     GROUP 1 — LASER TREATMENTS
     ════════════════════════════════════════════════ -->
<section class="lsc-tc__group lsc-tc__group--warm-white" id="laser">
  <div class="lsc-tc__group-inner">
    <div class="lsc-tc__group-header">
      <p class="lsc-tc__group-eyebrow">LASER TREATMENTS</p>
      <h2 class="lsc-tc__group-title">Advanced Laser Treatments</h2>
    </div>

    <div class="lsc-tc__grid">
      {%- assign laser_names = 'Laser Hair Removal,CO₂ Laser Resurfacing,Laser Tattoo Removal,IPL' | split: ',' -%}
      {%- assign laser_urls = '/products/laser-hair-removal,/products/co2-laser-resurfacing,/products/laser-tattoo-removal,/products/ipl' | split: ',' -%}
      {%- assign laser_descs = 'Permanent hair reduction using medical-grade diode laser technology for all skin types.,Fractional CO₂ laser for deep resurfacing — targets scars&#44; fine lines and uneven texture.,Safe&#44; effective laser removal for unwanted tattoos with minimal scarring.,Intense Pulsed Light therapy for pigmentation&#44; redness and sun damage.' | split: ',' -%}

      {%- for i in (0..3) -%}
        <a href="{{ laser_urls[i] }}" class="lsc-tc__card" style="animation-delay: {{ forloop.index | times: 0.1 }}s;">
          <div class="lsc-tc__card-image-wrap">
            {%- assign img_handle = laser_urls[i] | split: '/products/' | last -%}
            {%- assign product_ref = all_products[img_handle] -%}
            {%- if product_ref and product_ref.featured_image -%}
              <img
                class="lsc-tc__card-image"
                src="{{ product_ref.featured_image | image_url: width: 600 }}"
                alt="{{ laser_names[i] | escape }}"
                loading="lazy"
                width="600"
                height="800"
              >
            {%- else -%}
              <div class="lsc-tc__card-placeholder">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
              </div>
            {%- endif -%}
          </div>
          <div class="lsc-tc__card-content">
            <h3 class="lsc-tc__card-name">{{ laser_names[i] }}</h3>
            <p class="lsc-tc__card-desc">{{ laser_descs[i] | replace: '&#44;', ',' }}</p>
            <span class="lsc-tc__card-link">Learn More &rarr;</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

