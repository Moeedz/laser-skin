<style>
  #section-values-{{ section.id }} {
    background: var(--cream, #F7F3EE);
    padding: 5rem 6%;
  }

  #section-values-{{ section.id }} .values__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  #section-values-{{ section.id }} .values__eyebrow {
    text-align: center;
    font-family: 'Outfit', sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold, #C2A56E);
    margin-bottom: 0.6rem;
  }

  #section-values-{{ section.id }} .values__heading {
    text-align: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 400;
    color: var(--charcoal, #2C2C2C);
    margin: 0 0 3rem;
  }

  #section-values-{{ section.id }} .values__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
    justify-content: center;
  }

  #section-values-{{ section.id }} .value-card {
    background: #fff;
    padding: 2.2rem;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  #section-values-{{ section.id }} .value-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
  }

  #section-values-{{ section.id }} .value-card__icon {
    width: 40px;
    height: 40px;
    border: 1.5px solid var(--gold, #C2A56E);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--gold, #C2A56E);
  }

  #section-values-{{ section.id }} .value-card__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--charcoal, #2C2C2C);
    margin: 1.2rem 0 0.6rem;
  }

  #section-values-{{ section.id }} .value-card__description {
    font-family: 'Outfit', sans-serif;
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--dark-taupe, #6B5E50);
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    #section-values-{{ section.id }} .values__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 480px) {
    #section-values-{{ section.id }} .values__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<section id="section-values-{{ section.id }}">
  <div class="values__inner">
    <p class="values__eyebrow">{{ section.settings.eyebrow | default: 'WHY CHOOSE US' | upcase }}</p>
    <h2 class="values__heading">{{ section.settings.heading | default: 'Why Laser Skin Clinics' }}</h2>

    <div class="values__grid">
      {% for block in section.blocks %}
        <div class="value-card" {{ block.shopify_attributes }}>
          <div class="value-card__icon">
            {{ forloop.index }}
          </div>
          <h3 class="value-card__title">{{ block.settings.title }}</h3>
          <p class="value-card__description">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Values",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "WHY CHOOSE US"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Laser Skin Clinics"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Value Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A short description of this value proposition."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Values",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "title": "Consultation-Led Approach",
            "description": "Every treatment begins with a thorough consultation to understand your skin, your goals, and the best path forward."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Medical-Grade Technology",
            "description": "We invest in advanced laser and regenerative technology used by leading clinics across the UK."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Qualified Practitioners",
            "description": "Our team includes an NHS consultant physician and a Level 4 qualified laser specialist."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Honest, Transparent Care",
            "description": "No hard sell, no unnecessary upselling. Just expert advice and treatments that genuinely work for you."
          }
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
