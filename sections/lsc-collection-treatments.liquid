<style>
  /* ── Header ── */
  .lsc-ct__header {
    padding: 5rem 6% 3.5rem;
    background: var(--charcoal, #2C2824);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .lsc-ct__header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 80% at 50% 100%, rgba(196,169,125,0.07), transparent);
  }
  .lsc-ct__breadcrumb {
    font-family: 'Outfit', sans-serif;
    font-size: 0.68rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--taupe, #B8A99A);
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 2;
  }
  .lsc-ct__breadcrumb a {
    color: var(--taupe, #B8A99A);
    text-decoration: none;
  }
  .lsc-ct__breadcrumb a:hover { color: var(--gold, #C4A97D); }
  .lsc-ct__breadcrumb span { color: rgba(255,255,255,0.6); }
  .lsc-ct__eyebrow {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold, #C4A97D);
    margin-bottom: 0.8rem;
    position: relative;
    z-index: 2;
  }
  .lsc-ct__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 3.5vw, 3rem);
    font-weight: 300;
    line-height: 1.15;
    color: var(--warm-white, #FDFCFA);
    margin: 0 0 1rem;
    position: relative;
    z-index: 2;
  }
  .lsc-ct__intro {
    font-family: 'Outfit', sans-serif;
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(255,255,255,0.5);
    max-width: 520px;
    margin: 0 auto 2rem;
    position: relative;
    z-index: 2;
  }

  /* ── Jump Links ── */
  .lsc-ct__jumps {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
  }
  .lsc-ct__jump {
    font-family: 'Outfit', sans-serif;
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.5rem 1.2rem;
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    border-radius: 100px;
    transition: all 0.3s;
  }
  .lsc-ct__jump:hover {
    border-color: var(--gold, #C4A97D);
    color: var(--gold, #C4A97D);
  }

  /* ── Treatment Groups ── */
  .lsc-ct__group {
    padding: 4.5rem 6% 1rem;
  }
  .lsc-ct__group:first-of-type {
    padding-top: 3.5rem;
  }
  .lsc-ct__group-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    max-width: 1200px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    padding-bottom: 1rem;
  }
  .lsc-ct__group-num {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 0.58rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold, #C4A97D);
    margin-bottom: 0.3rem;
  }
  .lsc-ct__group-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 300;
    color: var(--charcoal, #2C2824);
    margin: 0;
  }
  .lsc-ct__group-count {
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    font-weight: 300;
    color: var(--taupe, #B8A99A);
  }

  /* ── Card Grid ── */
  .lsc-ct__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1200px;
    margin-bottom: 1rem;
  }

  /* ── Cards ── */
  .lsc-ct__card {
    position: relative;
    border: 1px solid rgba(0,0,0,0.05);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.25, 0, 0.25, 1);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: #fff;
  }
  .lsc-ct__card:hover {
    border-color: var(--gold, #C4A97D);
    box-shadow: 0 12px 40px rgba(0,0,0,0.06);
    transform: translateY(-3px);
  }

  .lsc-ct__card-img {
    aspect-ratio: 4 / 3;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--sand, #E8E0D5), var(--taupe, #B8A99A));
  }
  .lsc-ct__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .lsc-ct__card:hover .lsc-ct__card-img img {
    transform: scale(1.03);
  }

  .lsc-ct__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: 'Outfit', sans-serif;
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: var(--gold, #C4A97D);
    color: var(--deep, #1A1714);
    padding: 0.3rem 0.7rem;
    z-index: 2;
  }

  .lsc-ct__card-arrow {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 32px;
    height: 32px;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(6px);
    transition: all 0.3s;
    color: white;
  }
  .lsc-ct__card:hover .lsc-ct__card-arrow {
    opacity: 1;
    transform: translateY(0);
  }
  .lsc-ct__card-arrow svg {
    width: 12px;
    height: 12px;
  }

  .lsc-ct__card-body {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .lsc-ct__card-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--charcoal, #2C2824);
    margin: 0 0 0.5rem;
    line-height: 1.25;
  }
  .lsc-ct__card-desc {
    font-family: 'Outfit', sans-serif;
    font-size: 0.8rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--dark-taupe, #8A7B6B);
    flex-grow: 1;
    margin: 0 0 1rem;
  }
  .lsc-ct__card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid rgba(0,0,0,0.05);
  }
  .lsc-ct__card-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--charcoal, #2C2824);
  }
  .lsc-ct__card-link {
    font-family: 'Outfit', sans-serif;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold, #C4A97D);
    transition: color 0.3s;
  }
  .lsc-ct__card:hover .lsc-ct__card-link {
    color: var(--charcoal, #2C2824);
  }

  /* ── Concerns line ── */
  .lsc-ct__concerns {
    max-width: 1200px;
    margin-bottom: 3rem;
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    font-weight: 300;
    color: var(--taupe, #B8A99A);
    line-height: 1.6;
  }
  .lsc-ct__concerns strong {
    font-weight: 400;
    color: var(--dark-taupe, #8A7B6B);
  }

  /* ── CTA Section ── */
  .lsc-ct__cta {
    background: var(--charcoal, #2C2824);
    padding: 5rem 6%;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .lsc-ct__cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 50% 100%, rgba(196,169,125,0.06), transparent);
  }
  .lsc-ct__cta-ey {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-light, #D4BE9A);
    margin-bottom: 0.8rem;
    position: relative;
    z-index: 2;
  }
  .lsc-ct__cta-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 300;
    color: var(--warm-white, #FDFCFA);
    margin: 0 0 0.8rem;
    position: relative;
    z-index: 2;
  }
  .lsc-ct__cta-text {
    font-family: 'Outfit', sans-serif;
    font-size: 0.92rem;
