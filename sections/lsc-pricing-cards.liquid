{% comment %}
  LSC Pricing Cards Section
  Tiered pricing cards for Template A treatment pages.
  Reads from product.metafields.custom.pricing_structure (JSON) with block fallback.
{% endcomment %}

<style>
  .lsc-pricing-cards {
    background: var(--warm-white);
    padding: 5rem 6%;
  }

  .lsc-pricing-cards__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .lsc-pricing-cards__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.62rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--gold);
    margin-bottom: 0.8rem;
  }

  .lsc-pricing-cards__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 300;
    color: var(--charcoal);
    margin: 0;
  }

  .lsc-pricing-cards__grid {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    max-width: 1100px;
    margin: 0 auto;
    gap: 1.5rem;
  }

  .lsc-pricing-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.05);
    padding: 2.5rem 2rem;
    text-align: center;
    min-width: 240px;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
  }

  .lsc-pricing-card:hover {
    border-color: var(--gold);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .lsc-pricing-card__badge {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 0.58rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    padding: 0.35rem 1rem;
  }

  .lsc-pricing-card__tier {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--charcoal);
    margin-bottom: 0.8rem;
  }

  .lsc-pricing-card__price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 300;
    color: var(--charcoal);
    line-height: 1.2;
  }

  .lsc-pricing-card__save {
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--gold);
    margin-top: 0.3rem;
  }

  .lsc-pricing-card__description {
    font-family: 'Outfit', sans-serif;
    font-size: 0.8rem;
    font-weight: 300;
    color: var(--dark-taupe);
    margin-top: 0.5rem;
    margin-bottom: 2rem;
    line-height: 1.5;
  }

  .lsc-pricing-card__cta {
    margin-top: auto;
    width: 100%;
  }

  .lsc-pricing-card__btn {
    display: block;
    width: 100%;
    font-family: 'Outfit', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.85rem 1.5rem;
    background: var(--charcoal);
    color: #fff;
    border: 1px solid var(--charcoal);
    text-decoration: none;
    text-align: center;
    transition: background-color 0.3s ease, color 0.3s ease, transform 0.2s ease;
    cursor: pointer;
  }

  .lsc-pricing-card__btn:hover {
    background: transparent;
    color: var(--charcoal);
    transform: translateY(-1px);
  }

  .lsc-pricing-card__klarna {
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--gold);
    margin-top: -0.5rem;
    margin-bottom: 1.5rem;
  }

  .lsc-pricing-cards__finance-note {
    max-width: 600px;
    margin: 2.5rem auto 0;
    text-align: center;
  }

  .lsc-pricing-cards__finance-note p {
    font-family: 'Outfit', sans-serif;
    font-size: 0.78rem;
    font-weight: 300;
    color: var(--dark-taupe);
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 900px) {
    .lsc-pricing-cards__grid {
      max-width: 600px;
    }

    .lsc-pricing-card {
      min-width: calc(50% - 1.5rem);
      flex: 0 0 calc(50% - 0.75rem);
    }
  }

  @media screen and (max-width: 580px) {
    .lsc-pricing-cards {
      padding: 3rem 5%;
    }

    .lsc-pricing-cards__grid {
      flex-direction: column;
    }

    .lsc-pricing-card {
      min-width: 100%;
      flex: 1 1 100%;
    }
  }
</style>

<section class="lsc-pricing-cards">
  <div class="lsc-pricing-cards__header">
    <p class="lsc-pricing-cards__eyebrow">PRICING</p>
    <h2 class="lsc-pricing-cards__heading">Treatment Pricing</h2>
  </div>

  <div class="lsc-pricing-cards__grid">
    {%- assign pricing_meta = product.metafields.custom.pricing_structure -%}
    {%- assign blemish_handles = 'blemish-removal,skin-tag-removal,mole-removal,milia-removal,thread-vein-removal,age-spot-removal,cherry-angioma-removal,spider-naevi-removal,xanthelasma-removal,wart-and-verruca-removal,seborrheic-wart-removal' -%}

    {%- if blemish_handles contains product.handle -%}
      <div class="lsc-pricing-card">
        <p class="lsc-pricing-card__tier">{{ product.title }}</p>
        <p class="lsc-pricing-card__price">£75</p>
        <p class="lsc-pricing-card__description">Single session — Quick, comfortable, and hassle-free</p>
        <div class="lsc-pricing-card__cta">
          <a
            href="#lsc-contact"
            class="lsc-pricing-card__btn"
            onclick="var el=document.getElementById('lsc-contact');if(el){el.scrollIntoView({behavior:'smooth'});return false;}"
          >
            Book Now
          </a>
        </div>
      </div>

    {%- elsif section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div class="lsc-pricing-card" {{ block.shopify_attributes }}>
          {%- if block.settings.badge_text != blank -%}
            <div class="lsc-pricing-card__badge">{{ block.settings.badge_text }}</div>
          {%- elsif block.settings.popular -%}
            <div class="lsc-pricing-card__badge">Most Popular</div>
          {%- endif -%}

          <p class="lsc-pricing-card__tier">{{ block.settings.tier_name }}</p>
          <p class="lsc-pricing-card__price">{{ block.settings.price }}</p>
          {%- if block.settings.save_text != blank -%}
            <p class="lsc-pricing-card__save">{{ block.settings.save_text }}</p>
          {%- endif -%}
          <p class="lsc-pricing-card__description">{{ block.settings.description }}</p>

          <div class="lsc-pricing-card__cta">
            <a
              href="#lsc-contact"
              class="lsc-pricing-card__btn"
              onclick="var el=document.getElementById('lsc-contact');if(el){el.scrollIntoView({behavior:'smooth'});return false;}"
            >
              Book Now
            </a>
          </div>
        </div>
      {%- endfor -%}

    {%- elsif pricing_meta != blank -%}
      {%- assign pricing_data = pricing_meta.value -%}

      {%- for item in pricing_data -%}
        <div class="lsc-pricing-card">
          {%- if item.popular -%}
            <div class="lsc-pricing-card__badge">Most Popular</div>
          {%- endif -%}

          <p class="lsc-pricing-card__tier">{{ item.tier }}</p>
          <p class="lsc-pricing-card__price">{{ item.price }}</p>
          <p class="lsc-pricing-card__description">{{ item.description }}</p>

          <div class="lsc-pricing-card__cta">
            <a
              href="#lsc-contact"
              class="lsc-pricing-card__btn"
              onclick="var el=document.getElementById('lsc-contact');if(el){el.scrollIntoView({behavior:'smooth'});return false;}"
            >
              Book Now
            </a>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- assign klarna_handles = 'laser-hair-removal,co2-laser-resurfacing,dermaforce-rf-microneedling,nctf-skin-booster,exosomes,polynucleotides,emlift-facial-lifting,laser-tattoo-removal,melanopro-chemical-peel' -%}
  {%- if klarna_handles contains product.handle -%}
  <div class="lsc-pricing-cards__finance-note">
    <p>0% finance available — spread the cost with Klarna. Subject to eligibility.</p>
  </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Pricing Cards",
  "settings": [],
  "blocks": [
    {
      "type": "pricing_tier",
      "name": "Pricing Tier",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "tier_name",
          "label": "Tier Name",
          "default": "Single Session"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "£250"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "One treatment session"
        },
        {
          "type": "checkbox",
          "id": "popular",
          "label": "Most Popular?",
          "default": false
        },
        {
          "type": "text",
          "id": "save_text",
          "label": "Savings Text",
          "info": "e.g. 'Save £75' — shown below price in gold"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Custom Badge Text",
          "info": "Overrides the 'Most Popular' badge. e.g. 'Save 15%'"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Pricing Cards",
      "blocks": [
        {
          "type": "pricing_tier",
          "settings": {
            "tier_name": "Single Session",
            "price": "£250",
            "description": "One treatment session"
          }
        },
        {
          "type": "pricing_tier",
          "settings": {
            "tier_name": "Course of 3",
            "price": "£650",
            "description": "Three sessions with savings",
            "popular": true
          }
        },
        {
          "type": "pricing_tier",
          "settings": {
            "tier_name": "Course of 6",
            "price": "£1,100",
            "description": "Six sessions — best value"
          }
        }
      ]
    }
  ]
}
{% endschema %}
