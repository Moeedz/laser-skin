            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
          </div>
        {%- endif -%}
      </div>

      <div class="lsc-pkg__card-content">
        <h3 class="lsc-pkg__card-name">Tighten Clean &amp; Glow</h3>
        <p class="lsc-pkg__card-price">From &pound;149</p>

        <ul class="lsc-pkg__checklist">
          <li>RF Skin Tightening</li>
          <li>Hydrofacial Deep Cleanse</li>
          <li>Exosomes Booster</li>
        </ul>

        <div class="lsc-pkg__card-cta">
          <a href="/products/the-tighten-clean-glow-package" class="lsc-pkg__card-btn--view">View Package</a>
          {%- capture pkg2_msg -%}Hi! I would like to book the Tighten Clean and Glow package please.{%- endcapture -%}
          <a
            href="https://wa.me/447340485665?text={{ pkg2_msg | url_encode }}"
            class="lsc-pkg__card-btn"
            target="_blank"
            rel="noopener noreferrer"
            data-wa-type="package_book"
          >
            Book Now
          </a>
        </div>
      </div>
    </div>

    <!-- Package 3: Lift Heal & Glow -->
    <div class="lsc-pkg__card">
      <a href="/products/the-lift-heal-glow-supreme-package" class="lsc-pkg__card-overlay-link" aria-label="View Lift Heal and Glow package details"></a>
      <div class="lsc-pkg__card-image-wrap">
        {%- if pkg3_img -%}
          <img
            class="lsc-pkg__card-image"
            src="{{ pkg3_img | image_url: width: 700 }}"
            alt="Lift Heal and Glow treatment package at Laser Skin Clinics Wolverhampton — RF skin tightening, IPL glow facial, and Celluma LED therapy"
            loading="lazy"
            width="700"
            height="525"
          >
        {%- else -%}
          <div class="lsc-pkg__card-placeholder">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
          </div>
        {%- endif -%}
