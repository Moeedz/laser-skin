{% style %}
  .spr {
    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    width: 100%; overflow: hidden; position: relative;
    background-color: var(--section-bg);
    padding: var(--padding-top) 0 var(--padding-bottom);
  }

  .spr__texture {
    position: absolute; inset: 0; pointer-events: none; z-index: 0;
    opacity: var(--texture-opacity);
  }
  .spr__texture::before, .spr__texture::after { content: ''; position: absolute; inset: 0; }
  .spr__texture::before {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='5' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }
  .spr__texture::after {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='f'%3E%3CfeTurbulence type='turbulence' baseFrequency='0.015 0.06' numOctaves='4' seed='5' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23f)' opacity='0.05'/%3E%3C/svg%3E");
    background-size: 512px 512px;
  }

  .spr__container {
    position: relative; z-index: 1;
    max-width: 800px; margin: 0 auto; padding: 0 40px;
  }

  /* Heading */
  .spr__heading {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: var(--heading-size); font-weight: 400; font-style: italic;
    line-height: 1.2; color: var(--light-color);
    text-align: center; margin: 0 0 40px;
  }

  /* Rows */
  .spr__rows {
    display: flex; flex-direction: column;
  }

  .spr__divider {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.12) 15%, rgba(255,255,255,0.12) 85%, transparent);
  }

  .spr__row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 32px 20px;
  }

  /* Left: session name */
  .spr__row-name {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: calc(var(--body-size) + 6px); font-weight: 400;
    color: var(--light-color); margin: 0;
    line-height: 1.3;
  }

  /* Right: price stack */
  .spr__row-price-wrap {
    text-align: right;
    display: flex; flex-direction: column; align-items: flex-end; gap: 2px;
  }

  .spr__row-price {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: calc(var(--body-size) + 12px); font-weight: 400;
    color: var(--gold-color); line-height: 1.2;
  }

  .spr__row-per {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: calc(var(--body-size) - 1px); font-style: italic;
    color: var(--light-color); opacity: 0.6;
  }

  .spr__row-total {
    font-size: calc(var(--body-size) - 1px); font-style: italic;
    color: var(--light-color); opacity: 0.5;
  }

  /* Footer */
  .spr__footer {
    text-align: center; margin-top: 40px;
  }

  .spr__footer-text {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: var(--body-size); font-style: italic;
    color: var(--light-color); opacity: 0.7; margin: 0;
    line-height: 1.6;
  }

  /* Animations */
  [data-spr-animate] {
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
  }
  [data-spr-animate].is-visible { opacity: 1; transform: translateY(0); }

  /* Responsive */
  @media screen and (max-width: 768px) {
    .spr__container { padding: 0 20px; }
    .spr__heading { font-size: calc(var(--heading-size) * 0.7); margin-bottom: 28px; }
    .spr__row { padding: 24px 12px; }
    .spr__row-name { font-size: calc(var(--body-size) + 2px); }
    .spr__row-price { font-size: calc(var(--body-size) + 6px); }
  }

  @media screen and (max-width: 480px) {
    .spr__container { padding: 0 16px; }
    .spr__heading { font-size: calc(var(--heading-size) * 0.55); }
    .spr__row { padding: 20px 8px; }
    .spr__row-name { font-size: calc(var(--body-size) + 1px); }
    .spr__row-price { font-size: calc(var(--body-size) + 4px); }
  }
{% endstyle %}

{% assign row_blocks = section.blocks | where: 'type', 'price_row' %}

<section
  class="spr"
  id="spr-{{ section.id }}"
  style="
    --section-bg: {{ section.settings.section_bg }};
    --light-color: {{ section.settings.light_color }};
    --gold-color: {{ section.settings.gold_color }};
    --heading-size: {{ section.settings.heading_font_size }}px;
    --body-size: {{ section.settings.body_font_size }}px;
    --texture-opacity: {{ section.settings.texture_opacity | divided_by: 100.0 }};
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  {% if section.settings.show_texture %}<div class="spr__texture"></div>{% endif %}

  <div class="spr__container">
    {% if section.settings.heading != blank %}
      <h2 class="spr__heading" data-spr-animate data-delay="0">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if row_blocks.size > 0 %}
      <div class="spr__rows">
        <div class="spr__divider"></div>
        {% for block in row_blocks %}
          <div class="spr__row" data-spr-animate data-delay="{{ forloop.index }}" {{ block.shopify_attributes }}>
            <h3 class="spr__row-name">{{ block.settings.name }}</h3>
            <div class="spr__row-price-wrap">
              <span class="spr__row-price">{{ block.settings.price }}</span>
              {% if block.settings.per_label != blank %}
                <span class="spr__row-per">{{ block.settings.per_label }}</span>
              {% endif %}
              {% if block.settings.total != blank %}
                <span class="spr__row-total">({{ block.settings.total }})</span>
              {% endif %}
            </div>
          </div>
          <div class="spr__divider"></div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.footer_text != blank %}
      <div class="spr__footer" data-spr-animate data-delay="{{ row_blocks.size | plus: 1 }}">
        <p class="spr__footer-text">{{ section.settings.footer_text }}</p>
      </div>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var s = document.getElementById('spr-{{ section.id }}');
    if (!s) return;
    var els = s.querySelectorAll('[data-spr-animate]');
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          var d = parseInt(e.target.getAttribute('data-delay') || '0', 10);
          setTimeout(function () { e.target.classList.add('is-visible'); }, d * 120);
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    els.forEach(function (el) { obs.observe(el); });
  });
</script>

{% schema %}
{
  "name": "Simple Pricing Rows",
  "tag": "section",
  "class": "simple-pricing-rows-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "IPL Pricing" },
    { "type": "textarea", "id": "footer_text", "label": "Footer Text", "default": "A course of sessions delivers greater value and long-lasting results." },
    { "type": "header", "content": "Background" },
    { "type": "color", "id": "section_bg", "label": "Section Background", "default": "#3a3a42" },
    { "type": "checkbox", "id": "show_texture", "label": "Show Fabric Texture", "default": true },
    { "type": "range", "id": "texture_opacity", "label": "Texture Intensity", "min": 0, "max": 100, "step": 5, "default": 90, "unit": "%" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "light_color", "label": "Text Color", "default": "#e0d8d0" },
    { "type": "color", "id": "gold_color", "label": "Price Color", "default": "#d4c4a0" },
    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_font_size", "label": "Heading Font Size", "min": 28, "max": 56, "step": 2, "default": 42, "unit": "px" },
    { "type": "range", "id": "body_font_size", "label": "Body Font Size", "min": 14, "max": 20, "step": 1, "default": 16, "unit": "px" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 0, "max": 120, "step": 4, "default": 60, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 120, "step": 4, "default": 60, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "price_row",
      "name": "Pricing Row",
      "settings": [
        { "type": "text", "id": "name", "label": "Session Name", "default": "1 Session" },
        { "type": "text", "id": "price", "label": "Price", "default": "£80" },
        { "type": "text", "id": "per_label", "label": "Per Label (optional)", "info": "e.g. per session" },
        { "type": "text", "id": "total", "label": "Total (optional)", "info": "e.g. Total £210" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Simple Pricing Rows",
      "blocks": [
        { "type": "price_row", "settings": { "name": "1 Session", "price": "£80" } },
        { "type": "price_row", "settings": { "name": "3 Sessions", "price": "£70", "per_label": "per session", "total": "Total £210" } },
        { "type": "price_row", "settings": { "name": "6 Sessions", "price": "£60", "per_label": "per session", "total": "Total £360" } }
      ]
    }
  ]
}
{% endschema %}
