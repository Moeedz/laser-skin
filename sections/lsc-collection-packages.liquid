{%- comment -%}
  LSC Collection Packages
  Custom packages collection page replacing the default collection grid.
  Only renders when collection.handle == 'bundles'.
{%- endcomment -%}

{%- comment -%} Build product image lookup via all_products {%- endcomment -%}
{%- assign pkg1_product = all_products['sculpt-cleanse-glow-signature-package'] -%}
{%- assign pkg2_product = all_products['the-tighten-clean-glow-package'] -%}
{%- assign pkg3_product = all_products['the-lift-heal-glow-supreme-package'] -%}
{%- assign pkg1_img = pkg1_product.featured_image -%}
{%- assign pkg2_img = pkg2_product.featured_image -%}
{%- assign pkg3_img = pkg3_product.featured_image -%}

<style>
  :root {
    --gold: #C4A97D;
    --gold-light: #D4BE9A;
    --deep: #1A1714;
    --charcoal: #2C2824;
    --cream: #F7F3EE;
    --warm-white: #FAF8F5;
    --dark-taupe: #6B5E53;
    --sand: #D6CEC4;
    --taupe: #8B7E74;
  }

  .lsc-pkg__header {
    background: var(--charcoal);
    padding: 8rem 6% 3rem;
    text-align: center;
  }

  .lsc-pkg__breadcrumb {
    font-family: 'Outfit', sans-serif;
    font-size: 0.72rem;
    font-weight: 300;
    color: var(--taupe);
    margin: 0 0 1.5rem;
  }

  .lsc-pkg__breadcrumb a {
    color: var(--sand);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .lsc-pkg__breadcrumb a:hover {
    color: var(--gold);
  }

  .lsc-pkg__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 1rem;
  }

  .lsc-pkg__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 300;
    color: #ffffff;
    line-height: 1.15;
    margin: 0 0 0.8rem;
  }

  .lsc-pkg__intro {
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--sand);
    max-width: 550px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .lsc-pkg__section {
    background: var(--warm-white);
    padding: 5rem 6%;
  }

  .lsc-pkg__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .lsc-pkg__card {
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.05);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
    cursor: pointer;
  }

  .lsc-pkg__card:hover {
    border-color: var(--gold);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .lsc-pkg__card-overlay-link {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: block;
  }

  .lsc-pkg__card-cta {
    position: relative;
    z-index: 2;
    margin-top: auto;
  }

  .lsc-pkg__card-btn--view {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.9rem 1.5rem;
    background: var(--charcoal);
    color: #ffffff;
    border: 1px solid var(--charcoal);
    font-family: 'Outfit', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s ease, color 0.3s ease, transform 0.2s ease;
    box-sizing: border-box;
  }

  .lsc-pkg__card-btn--view:hover {
    background: transparent;
    color: var(--charcoal);
    transform: translateY(-1px);
  }

  .lsc-pkg__card--popular {
    border-color: var(--gold);
  }

  .lsc-pkg__badge {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: #ffffff;
    font-family: 'Outfit', sans-serif;
    font-size: 0.58rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    padding: 0.4rem 1.2rem;
    z-index: 2;
    white-space: nowrap;
  }

  .lsc-pkg__card-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #e8e2da;
  }

  .lsc-pkg__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .lsc-pkg__card:hover .lsc-pkg__card-image {
    transform: scale(1.03);
  }

  .lsc-pkg__card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e2da;
  }

  .lsc-pkg__card-placeholder svg {
    width: 40px;
    height: 40px;
    stroke: #c4b9ab;
    fill: none;
    stroke-width: 1;
  }

  .lsc-pkg__card-content {
    padding: 2rem 1.8rem 2.2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    text-align: center;
  }

  .lsc-pkg__card-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--deep);
    margin: 0 0 0.6rem;
    line-height: 1.3;
  }

  .lsc-pkg__card-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--deep);
    margin: 0 0 1.5rem;
    line-height: 1.2;
  }

  .lsc-pkg__checklist {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    text-align: left;
  }

  .lsc-pkg__checklist li {
    font-family: 'Outfit', sans-serif;
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--dark-taupe);
    line-height: 1.5;
    padding: 0.35rem 0;
    padding-left: 1.6rem;
    position: relative;
  }

  .lsc-pkg__checklist li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 10px;
    height: 5px;
    background: none;
    border-left: 2px solid var(--gold);
    border-bottom: 2px solid var(--gold);
    transform: rotate(-45deg);
  }

  .lsc-pkg__card-btn {
    display: block;
    width: 100%;
    font-family: 'Outfit', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.75rem 1.5rem;
    background: transparent;
    color: var(--charcoal);
    border: 1px solid var(--charcoal);
    text-decoration: none;
    text-align: center;
    transition: background 0.3s ease, color 0.3s ease, transform 0.2s ease;
    cursor: pointer;
    box-sizing: border-box;
    margin-top: 0.6rem;
  }

  .lsc-pkg__card-btn:hover {
    background: var(--charcoal);
    color: #fff;
    transform: translateY(-1px);
  }

  .lsc-pkg__card--popular .lsc-pkg__card-btn--view {
    background: var(--gold);
    border-color: var(--gold);
    color: #ffffff;
  }

  .lsc-pkg__card--popular .lsc-pkg__card-btn--view:hover {
    background: transparent;
    color: var(--gold);
  }

  .lsc-pkg__unsure {
    background: var(--cream);
    padding: 4.5rem 6%;
    text-align: center;
  }

  .lsc-pkg__unsure-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    font-weight: 300;
    color: var(--deep);
    margin: 0 0 0.6rem;
  }

  .lsc-pkg__unsure-desc {
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--dark-taupe);
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .lsc-pkg__unsure-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.95rem 2rem;
    background: #25D366;
    color: #ffffff;
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .lsc-pkg__unsure-btn:hover {
    background: #20bd5a;
    transform: translateY(-1px);
  }

  .lsc-pkg__unsure-btn svg {
    flex-shrink: 0;
  }

  .lsc-pkg__unsure-alt {
    font-family: 'Outfit', sans-serif;
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--dark-taupe);
    margin: 1.5rem 0 0;
    line-height: 1.6;
  }

  .lsc-pkg__unsure-alt a {
    color: var(--charcoal);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .lsc-pkg__unsure-alt a:hover {
    color: var(--gold);
  }

  @media screen and (max-width: 900px) {
    .lsc-pkg__grid {
      grid-template-columns: 1fr 1fr;
      max-width: 740px;
    }
  }

  @media screen and (max-width: 580px) {
    .lsc-pkg__header {
      padding: 7rem 5% 2.5rem;
    }

    .lsc-pkg__section {
      padding: 3.5rem 5%;
    }

    .lsc-pkg__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
    }

    .lsc-pkg__unsure {
      padding: 3rem 5%;
    }
  }
</style>

<!-- ═══ DARK HEADER ═══ -->
<section class="lsc-pkg__header">
  <p class="lsc-pkg__breadcrumb"><a href="/">Home</a> &nbsp;/&nbsp; <span>Packages</span></p>
  <p class="lsc-pkg__eyebrow">VALUE PACKAGES</p>
  <h1 class="lsc-pkg__heading">Treatment Packages</h1>
  <p class="lsc-pkg__intro">Premium treatment bundles designed to deliver maximum results in a single session — saving you time and money.</p>
</section>

<!-- ═══ PACKAGE CARDS ═══ -->
<section class="lsc-pkg__section">
  <div class="lsc-pkg__grid">

    <!-- Package 1: Sculpt Cleanse & Glow -->
    <div class="lsc-pkg__card">
      <a href="/products/sculpt-cleanse-glow-signature-package" class="lsc-pkg__card-overlay-link" aria-label="View Sculpt Cleanse and Glow package details"></a>
      <div class="lsc-pkg__card-image-wrap">
        {%- if pkg1_img -%}
          <img
            class="lsc-pkg__card-image"
            src="{{ pkg1_img | image_url: width: 700 }}"
            alt="Sculpt Cleanse and Glow treatment package at Laser Skin Clinics Wolverhampton — PowerSculpt body sculpting, carbon facial, and red light therapy"
            loading="lazy"
            width="700"
            height="525"
          >
        {%- else -%}
          <div class="lsc-pkg__card-placeholder">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
          </div>
        {%- endif -%}
      </div>

      <div class="lsc-pkg__card-content">
        <h3 class="lsc-pkg__card-name">Sculpt Cleanse &amp; Glow</h3>
        <p class="lsc-pkg__card-price">From &pound;99</p>

        <ul class="lsc-pkg__checklist">
          <li>PowerSculpt Body Sculpting</li>
          <li>Carbon Facial</li>
          <li>Red Light Therapy</li>
        </ul>

        <div class="lsc-pkg__card-cta">
          <a href="/products/sculpt-cleanse-glow-signature-package" class="lsc-pkg__card-btn--view">View Package</a>
          {%- capture pkg1_msg -%}Hi! I would like to book the Sculpt Cleanse and Glow package please.{%- endcapture -%}
          <a
            href="https://wa.me/447340485665?text={{ pkg1_msg | url_encode }}"
            class="lsc-pkg__card-btn"
            target="_blank"
            rel="noopener noreferrer"
            data-wa-type="package_book"
          >
            Book Now
          </a>
        </div>
      </div>
    </div>

    <!-- Package 2: Tighten Clean & Glow (MOST POPULAR) -->
