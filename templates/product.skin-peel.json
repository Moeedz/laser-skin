    "ss_steps_11_7cMyRT": {
      "type": "ss-steps-11",
      "blocks": {
        "step_jmRN9F": {
          "type": "step",
          "settings": {
            "step": "STEP 1",
            "title": "CONSULTATION",
            "text": "<p>Your consultation will be done on the day of your treatment, an extra consultation session is not needed.<br/><br/>We will begin with a detailed consultation by one of our qualified professionals.<br/><br/>We evaluate your skin type, texture, and areas of concern to decide whether this treatment is suitable for you<br/><br/>Your personalised plan is designed to deliver maximum improvement safely and effectively.</p>"
          }
        },
        "step_jiiz8x": {
          "type": "step",
          "settings": {
            "step": "STEP 2",
            "title": "PROCEDURE",
            "text": "<p>During the treatment, targeted pulses of CO2 laser energy penetrate the skin to remove or heat specific layers.<br/><br/>The treatment removes damaged cells from the surface and remodels collagen beneath the surface.</p>"
          }
        },
        "step_6jaGgE": {
          "type": "step",
          "settings": {
            "step": "STEP 3",
            "title": "RECOVERY",
            "text": "<p>Following your session, the skin naturally begins its healing process.<br/><br/>With ablative resurfacing, you can expect redness and light peeling for several days as new, fresh skin emerges.<br/><br/>With non-ablative resurfacing, recovery is quicker, with only mild redness for a day or two.<br/><br/>Over the coming weeks, new collagen is produced, improving skin firmness, smoothness, and overall radiance.</p>"
          }
        }
      },
      "block_order": [
        "step_jmRN9F",
        "step_jiiz8x",
        "step_6jaGgE"
      ],
