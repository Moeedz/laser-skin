{%- comment -%}
  LSC Packages Section
  Shows 3 bundle package cards on the homepage.
{%- endcomment -%}

<section class="lsc-packages">
  <div class="lsc-packages__inner">

    <div class="lsc-packages__header">
      <span class="lsc-packages__eyebrow">SAVE WITH A PACKAGE</span>
      <h2 class="lsc-packages__heading">Our Packages</h2>
    </div>

    <div class="lsc-packages__cards">

      <a href="/products/sculpt-cleanse-glow-signature-package" class="lsc-packages__card">
        <div class="lsc-packages__card-content">
          <h3 class="lsc-packages__card-title">Sculpt, Cleanse & Glow</h3>
          <p class="lsc-packages__card-desc">Body contouring, deep cleanse, and skin radiance</p>
          <span class="lsc-packages__card-price">£99</span>
        </div>
        <span class="lsc-packages__card-arrow">&rarr;</span>
      </a>

      <a href="/products/the-tighten-clean-glow-package" class="lsc-packages__card lsc-packages__card--popular">
        <span class="lsc-packages__badge">MOST POPULAR</span>
        <div class="lsc-packages__card-content">
          <h3 class="lsc-packages__card-title">Tighten, Clean & Glow</h3>
          <p class="lsc-packages__card-desc">RF tightening, Hydrofacial, and exosomes regeneration</p>
          <span class="lsc-packages__card-price">£149</span>
        </div>
        <span class="lsc-packages__card-arrow">&rarr;</span>
      </a>

      <a href="/products/the-lift-heal-glow-supreme-package" class="lsc-packages__card">
        <div class="lsc-packages__card-content">
          <h3 class="lsc-packages__card-title">Lift, Heal & Glow</h3>
          <p class="lsc-packages__card-desc">Skin tightening, IPL glow, and LED healing</p>
          <span class="lsc-packages__card-price">£99</span>
        </div>
        <span class="lsc-packages__card-arrow">&rarr;</span>
      </a>

    </div>

    <div class="lsc-packages__cta-wrap">
      <a href="/collections/bundles" class="lsc-packages__cta">View All Packages &rarr;</a>
    </div>

  </div>
</section>

<style>
  .lsc-packages {
    background: var(--warm-white, #FAF8F5);
    padding: 5rem 6%;
  }

  .lsc-packages__inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .lsc-packages__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .lsc-packages__eyebrow {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold, #C4A97D);
    margin-bottom: 0.8rem;
  }

  .lsc-packages__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 300;
    color: var(--charcoal, #2C2C2C);
    margin: 0;
    line-height: 1.2;
  }

  /* ── Cards ── */
  .lsc-packages__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .lsc-packages__card {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 12px;
    padding: 1.75rem 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .lsc-packages__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: var(--gold, #C4A97D);
  }

  /* ── Most Popular badge ── */
  .lsc-packages__card--popular {
    border-color: var(--gold, #C4A97D);
  }

  .lsc-packages__badge {
    position: absolute;
    top: -0.6rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold, #C4A97D);
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.25rem 0.9rem;
    border-radius: 20px;
    white-space: nowrap;
  }

  .lsc-packages__card-content {
    flex: 1;
    min-width: 0;
  }

  .lsc-packages__card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--charcoal, #2C2C2C);
    margin: 0 0 0.35rem 0;
  }

  .lsc-packages__card-desc {
    font-family: 'Outfit', sans-serif;
    font-size: 0.78rem;
    font-weight: 300;
    color: var(--dark-taupe, #6B5E54);
    margin: 0 0 0.6rem 0;
    line-height: 1.45;
  }

  .lsc-packages__card-price {
    display: inline-block;
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--gold, #C4A97D);
  }

  .lsc-packages__card-arrow {
    flex-shrink: 0;
    font-size: 1.1rem;
    color: var(--gold, #C4A97D);
    transition: transform 0.25s ease;
  }

  .lsc-packages__card:hover .lsc-packages__card-arrow {
    transform: translateX(3px);
  }

  /* ── CTA ── */
  .lsc-packages__cta-wrap {
    text-align: center;
    margin-top: 2rem;
  }

  .lsc-packages__cta {
    display: inline-block;
    font-family: 'Outfit', sans-serif;
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold, #C4A97D);
    text-decoration: none;
    border-bottom: 1px solid var(--gold, #C4A97D);
    padding-bottom: 0.2rem;
    transition: color 0.25s ease, border-color 0.25s ease;
  }

  .lsc-packages__cta:hover {
    color: var(--charcoal, #2C2C2C);
    border-color: var(--charcoal, #2C2C2C);
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .lsc-packages {
      padding: 3.5rem 5%;
    }

    .lsc-packages__cards {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .lsc-packages__card--popular {
      order: -1;
    }
  }
</style>

{% schema %}
{
  "name": "Packages",
  "settings": [],
  "presets": [
    {
      "name": "Packages"
    }
  ]
}
{% endschema %}
