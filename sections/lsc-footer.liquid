    <!-- Column 1: Brand -->
    <div class="lsc-footer__col">
      <p class="lsc-footer__brand-name">Laser Skin Clinics</p>
      <p class="lsc-footer__tagline">Advanced laser and regenerative skin treatments in Wolverhampton.</p>
    </div>

    <!-- Column 2: Treatments -->
    <div class="lsc-footer__col">
      <p class="lsc-footer__heading">Treatments</p>
      <ul class="lsc-footer__links">
        <li><a href="/products/laser-hair-removal">Laser Hair Removal</a></li>
        <li><a href="/products/co2-laser-resurfacing">CO&#8322; Laser Resurfacing</a></li>
        <li><a href="/products/anti-wrinkle-injections">Anti-Wrinkle Injections</a></li>
        <li><a href="/products/dermaforce-rf-microneedling">RF Microneedling</a></li>
        <li><a href="/pages/blemish-removal">Blemish Removal</a></li>
      </ul>
    </div>

    <!-- Column 3: Clinic -->
    <div class="lsc-footer__col">
      <p class="lsc-footer__heading">Clinic</p>
      <ul class="lsc-footer__links">
        <li><a href="/pages/about-us">About Us</a></li>
        <li><a href="/pages/free-skin-assessment">Free Skin Assessment</a></li>
        <li><a href="/pages/packages">Packages</a></li>
        <li><a href="/products/laser-skin-clinics-gift-card">Gift Cards</a></li>
        <li><a href="/pages/contact">Contact</a></li>
      </ul>
    </div>

    <!-- Column 4: Legal -->
    <div class="lsc-footer__col">
      <p class="lsc-footer__heading">Legal</p>
      <ul class="lsc-footer__links">
        <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
        <li><a href="/policies/terms-of-service">Terms &amp; Conditions</a></li>
      </ul>
    </div>

  </div>

  <!-- Bottom Bar -->
  <div class="lsc-footer__bottom">
    <p class="lsc-footer__copyright">&copy; 2026 Laser Skin Clinics. All rights reserved.</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "lsc-footer-section",
  "settings": []
}
{% endschema %}
