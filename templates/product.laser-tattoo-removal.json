      "type": "lsc-how-it-works",
      "blocks": {
        "step_1": {
          "type": "step",
          "settings": {
            "title": "Consultation & Patch Test",
            "description": "Your tattoo is assessed for ink type, depth, and colour. A patch test is performed to confirm safe laser settings."
          }
        },
        "step_2": {
          "type": "step",
          "settings": {
            "title": "Skin Preparation",
            "description": "The area is cleaned and protective eyewear provided."
          }
        },
        "step_3": {
          "type": "step",
          "settings": {
            "title": "Laser Treatment",
            "description": "The Q-switched laser delivers rapid pulses that shatter the ink particles beneath the skin. You may feel a snapping sensation."
          }
        },
        "step_4": {
          "type": "step",
          "settings": {
            "title": "Aftercare & Healing",
            "description": "A soothing cream and dressing are applied. Your body's immune system gradually flushes the shattered ink over the following weeks."
          }
        }
      },
