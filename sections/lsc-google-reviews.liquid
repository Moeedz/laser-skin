{% comment %}
  LSC Google Reviews Section
  Displays Google reviews from metafields or section blocks with structured data
{% endcomment %}

{%- liquid
  assign bg_class = 'lsc-google-reviews--warm-white'
  if section.settings.background_color == 'cream'
    assign bg_class = 'lsc-google-reviews--cream'
  endif

  assign heading_text = section.settings.section_heading | default: 'What Our Clients Say'

  assign reviews = blank
  assign use_blocks = false
  assign use_metafields = false

  if section.blocks.size > 0
    assign use_blocks = true
  elsif product.metafields.custom.google_reviews != blank
    assign reviews = product.metafields.custom.google_reviews.value
    assign use_metafields = true
  endif
-%}

<section class="lsc-google-reviews {{ bg_class }}">
  <div class="lsc-google-reviews__header">
    <span class="lsc-google-reviews__eyebrow">REAL RESULTS</span>
    <h2 class="lsc-google-reviews__heading">{{ heading_text }}</h2>
  </div>

  <!-- Rating Badge -->
  <div class="lsc-google-reviews__rating-badge">
    <span class="lsc-google-reviews__rating-number">4.9</span>
    <span class="lsc-google-reviews__rating-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
    <span class="lsc-google-reviews__rating-source">
      from
      <svg class="lsc-google-reviews__google-logo" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 48 48">
        <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/>
        <path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/>
        <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0124 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/>
        <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 01-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/>
      </svg>
      Google reviews
    </span>
  </div>

  <!-- Reviews Grid -->
  <div class="lsc-google-reviews__grid">
    {% if use_blocks %}
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <div class="lsc-google-reviews__card" {{ block.shopify_attributes }}>
            <div class="lsc-google-reviews__card-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="lsc-google-reviews__card-text">"{{ block.settings.text }}"</p>
            <div class="lsc-google-reviews__card-footer">
              <span class="lsc-google-reviews__card-author">{{ block.settings.author }}</span>
              {% if block.settings.treatment != blank %}
                <span class="lsc-google-reviews__card-treatment">{{ block.settings.treatment }}</span>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    {% elsif use_metafields %}
      {% for review in reviews %}
        <div class="lsc-google-reviews__card">
          <div class="lsc-google-reviews__card-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="lsc-google-reviews__card-text">"{{ review.text }}"</p>
          <div class="lsc-google-reviews__card-footer">
            <span class="lsc-google-reviews__card-author">{{ review.author }}</span>
            {% if review.treatment != blank %}
              <span class="lsc-google-reviews__card-treatment">{{ review.treatment }}</span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>

<!-- Review Schema Markup (JSON-LD) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": {{ shop.name | json }},
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "bestRating": "5",
    "ratingCount": "246"
  },
  "review": [
    {% if use_blocks %}
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          {
            "@type": "Review",
            "reviewRating": {
              "@type": "Rating",
              "ratingValue": "5",
              "bestRating": "5"
            },
            "author": {
              "@type": "Person",
              "name": {{ block.settings.author | json }}
            },
            "reviewBody": {{ block.settings.text | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endif %}
      {% endfor %}
    {% elsif use_metafields %}
      {% for review in reviews %}
        {
          "@type": "Review",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5"
          },
          "author": {
            "@type": "Person",
            "name": {{ review.author | json }}
          },
          "reviewBody": {{ review.text | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    {% endif %}
  ]
}
</script>

<style>
  .lsc-google-reviews {
    padding: 5rem 6%;
  }

  .lsc-google-reviews--warm-white {
    background: var(--warm-white, #FAF8F5);
  }

  .lsc-google-reviews--cream {
    background: var(--cream, #F7F3EE);
  }

  .lsc-google-reviews__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .lsc-google-reviews__eyebrow {
    display: block;
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--taupe, #8B7E74);
    margin-bottom: 0.75rem;
  }

  .lsc-google-reviews__heading {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 2.2rem;
    font-weight: 400;
    color: var(--charcoal, #2C2C2C);
    margin: 0;
  }

  /* Rating Badge */
  .lsc-google-reviews__rating-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .lsc-google-reviews__rating-number {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 2rem;
    font-weight: 600;
    color: var(--charcoal, #2C2C2C);
    line-height: 1;
  }

  .lsc-google-reviews__rating-stars {
    color: #FBBC05;
    font-size: 1.2rem;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .lsc-google-reviews__rating-source {
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.82rem;
    color: var(--taupe, #8B7E74);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .lsc-google-reviews__google-logo {
    flex-shrink: 0;
  }

  /* Reviews Grid */
  .lsc-google-reviews__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    max-width: 1100px;
    margin: 0 auto;
    gap: 2rem;
  }

  /* Review Card */
  .lsc-google-reviews__card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.05);
    padding: 2rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .lsc-google-reviews__card:hover {
    border-color: var(--gold, #C4A87C);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .lsc-google-reviews__card-stars {
    color: #FBBC05;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .lsc-google-reviews__card-text {
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.88rem;
    font-weight: 300;
    font-style: italic;
    color: var(--dark-taupe, #6B5E54);
    line-height: 1.7;
    margin: 0 0 1.25rem 0;
  }

  .lsc-google-reviews__card-footer {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .lsc-google-reviews__card-author {
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--charcoal, #2C2C2C);
  }

  .lsc-google-reviews__card-treatment {
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--taupe, #8B7E74);
  }

  /* Responsive: Tablet */
  @media screen and (max-width: 768px) {
    .lsc-google-reviews {
      padding: 3.5rem 6%;
    }

    .lsc-google-reviews__grid {
      grid-template-columns: 1fr 1fr;
    }

    .lsc-google-reviews__heading {
      font-size: 1.8rem;
    }

    .lsc-google-reviews__rating-number {
      font-size: 1.6rem;
    }

    .lsc-google-reviews__rating-stars {
      font-size: 1rem;
    }
  }

  /* Responsive: Mobile */
  @media screen and (max-width: 480px) {
    .lsc-google-reviews__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .lsc-google-reviews__rating-badge {
      gap: 0.4rem;
    }

    .lsc-google-reviews__rating-number {
      font-size: 1.4rem;
    }

    .lsc-google-reviews__rating-stars {
      font-size: 0.9rem;
    }

    .lsc-google-reviews__rating-source {
      font-size: 0.75rem;
    }
  }
</style>

{% schema %}
{
  "name": "Google Reviews",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "What Our Clients Say"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
      "options": [
        {
          "value": "warm-white",
          "label": "Warm White"
        },
        {
          "value": "cream",
          "label": "Cream"
        }
      ],
      "default": "warm-white"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name"
        },
        {
          "type": "text",
          "id": "treatment",
          "label": "Treatment"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Google Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "text": "Absolutely amazing experience. The results exceeded my expectations and the team made me feel so comfortable throughout.",
            "author": "Sarah M.",
            "treatment": "Dermal Fillers"
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "I've been coming here for over a year now and the results are consistently outstanding. Highly recommend to anyone considering treatment.",
            "author": "Jessica L.",
            "treatment": "Anti-Wrinkle Treatment"
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "Professional, knowledgeable and genuinely caring. The consultation was thorough and I felt completely at ease. Beautiful, natural results.",
            "author": "Emma R.",
            "treatment": "Skin Consultation"
          }
        }
      ]
    }
  ]
}
{% endschema %}
