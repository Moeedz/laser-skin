<style>
  .lsc-page-header {
    background: var(--charcoal, #2C2824);
    padding: 8rem 6% 4rem;
    text-align: center;
  }

  .lsc-page-header__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold, #C5A467);
    margin-bottom: 1rem;
  }

  .lsc-page-header__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.6rem);
    font-weight: 400;
    color: #FFFFFF;
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .lsc-page-header__subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    max-width: 560px;
    margin: 0 auto;
  }
</style>

<section class="lsc-page-header" id="section-{{ section.id }}">
  {%- if section.settings.eyebrow != blank -%}
    <p class="lsc-page-header__eyebrow">{{ section.settings.eyebrow }}</p>
  {%- endif -%}

  {%- if section.settings.heading != blank -%}
    <h1 class="lsc-page-header__heading">{{ section.settings.heading }}</h1>
  {%- endif -%}

  {%- if section.settings.subtitle != blank -%}
    <p class="lsc-page-header__subtitle">{{ section.settings.subtitle }}</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Page Header",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Laser Skin Clinics"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page Title"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    }
  ],
  "presets": [
    {
      "name": "Page Header"
    }
  ]
}
{% endschema %}
