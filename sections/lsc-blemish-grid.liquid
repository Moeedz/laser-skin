{%- comment -%}
  LSC Blemish Type Grid
  Centrepiece section for the blemish hub page.
  10 clickable cards linking to individual blemish pages + 1 "Not Sure" card.
{%- endcomment -%}

<section class="lsc-blemish-grid" id="blemish-grid">
  <div class="lsc-blemish-grid__inner">

    <div class="lsc-blemish-grid__header">
      <span class="lsc-blemish-grid__eyebrow">WHAT WOULD YOU LIKE REMOVED?</span>
      <h2 class="lsc-blemish-grid__heading">Select Your Blemish Type</h2>
    </div>

    <div class="lsc-blemish-grid__cards">

      <a href="/products/skin-tag-removal" class="lsc-blemish-grid__card">
        <div class="lsc-blemish-grid__card-content">
          <h3 class="lsc-blemish-grid__card-title">Skin Tags</h3>
          <p class="lsc-blemish-grid__card-desc">Small, soft growths that hang from the skin on a thin stalk</p>
        </div>
        <span class="lsc-blemish-grid__card-arrow">&rarr;</span>
      </a>

      <a href="/products/mole-removal" class="lsc-blemish-grid__card">
        <div class="lsc-blemish-grid__card-content">
          <h3 class="lsc-blemish-grid__card-title">Moles</h3>
          <p class="lsc-blemish-grid__card-desc">Pigmented spots suitable for cosmetic removal</p>
        </div>
        <span class="lsc-blemish-grid__card-arrow">&rarr;</span>
      </a>

      <a href="/products/milia-removal" class="lsc-blemish-grid__card">
        <div class="lsc-blemish-grid__card-content">
          <h3 class="lsc-blemish-grid__card-title">Milia</h3>
          <p class="lsc-blemish-grid__card-desc">Hard white bumps trapped beneath the skin surface</p>
        </div>
        <span class="lsc-blemish-grid__card-arrow">&rarr;</span>
      </a>

      <a href="/products/thread-vein-removal" class="lsc-blemish-grid__card">
        <div class="lsc-blemish-grid__card-content">
          <h3 class="lsc-blemish-grid__card-title">Thread Veins</h3>
          <p class="lsc-blemish-grid__card-desc">Tiny visible blood vessels on the face and nose</p>
        </div>
        <span class="lsc-blemish-grid__card-arrow">&rarr;</span>
      </a>

      <a href="/products/age-spot-removal" class="lsc-blemish-grid__card">
        <div class="lsc-blemish-grid__card-content">
          <h3 class="lsc-blemish-grid__card-title">Age Spots</h3>
          <p class="lsc-blemish-grid__card-desc">Flat brown patches caused by sun exposure</p>
        </div>
        <span class="lsc-blemish-grid__card-arrow">&rarr;</span>
      </a>

      <a href="/products/cherry-angioma-removal" class="lsc-blemish-grid__card">
        <div class="lsc-blemish-grid__card-content">
          <h3 class="lsc-blemish-grid__card-title">Cherry Angiomas</h3>
          <p class="lsc-blemish-grid__card-desc">Small bright red spots from blood vessel overgrowth</p>
        </div>
        <span class="lsc-blemish-grid__card-arrow">&rarr;</span>
      </a>

      <a href="/products/spider-naevi-removal" class="lsc-blemish-grid__card">
        <div class="lsc-blemish-grid__card-content">
          <h3 class="lsc-blemish-grid__card-title">Spider Naevi</h3>
          <p class="lsc-blemish-grid__card-desc">Web-like clusters of blood vessels on the face and neck</p>
        </div>
        <span class="lsc-blemish-grid__card-arrow">&rarr;</span>
      </a>

      <a href="/products/xanthelasma-removal" class="lsc-blemish-grid__card">
        <div class="lsc-blemish-grid__card-content">
          <h3 class="lsc-blemish-grid__card-title">Xanthelasma</h3>
          <p class="lsc-blemish-grid__card-desc">Yellow cholesterol deposits on or around the eyelids</p>
        </div>
        <span class="lsc-blemish-grid__card-arrow">&rarr;</span>
      </a>

      <a href="/products/wart-and-verruca-removal" class="lsc-blemish-grid__card">
        <div class="lsc-blemish-grid__card-content">
          <h3 class="lsc-blemish-grid__card-title">Warts &amp; Verrucas</h3>
          <p class="lsc-blemish-grid__card-desc">Viral growths on the hands, feet, and body</p>
        </div>
        <span class="lsc-blemish-grid__card-arrow">&rarr;</span>
      </a>

      <a href="/products/seborrheic-wart-removal" class="lsc-blemish-grid__card">
        <div class="lsc-blemish-grid__card-content">
          <h3 class="lsc-blemish-grid__card-title">Seborrheic Warts</h3>
          <p class="lsc-blemish-grid__card-desc">Raised, waxy brown or black growths common with age</p>
        </div>
        <span class="lsc-blemish-grid__card-arrow">&rarr;</span>
      </a>

      <a href="https://wa.me/447798983387?text=Hi!%20I%20have%20a%20skin%20blemish%20I%27d%20like%20removed%20but%20I%27m%20not%20sure%20what%20type%20it%20is.%20Could%20I%20book%20an%20appointment%20please%3F" class="lsc-blemish-grid__card lsc-blemish-grid__card--unsure" target="_blank" rel="noopener" data-wa-type="not_sure">
        <div class="lsc-blemish-grid__card-content">
          <span class="lsc-blemish-grid__card-icon">?</span>
          <h3 class="lsc-blemish-grid__card-title">Not Sure What You Have?</h3>
          <p class="lsc-blemish-grid__card-desc">Book a free assessment and we'll identify your blemish and recommend the best treatment</p>
        </div>
        <span class="lsc-blemish-grid__card-arrow">&rarr;</span>
      </a>

    </div>
  </div>
</section>

<style>
  .lsc-blemish-grid {
    background: var(--warm-white, #FAF8F5);
    padding: 5rem 6%;
  }

  .lsc-blemish-grid__inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .lsc-blemish-grid__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .lsc-blemish-grid__eyebrow {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold, #C4A97D);
    margin-bottom: 0.6rem;
  }

  .lsc-blemish-grid__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 2.5vw, 2.4rem);
    font-weight: 400;
    color: var(--charcoal, #2C2C2C);
    margin: 0;
    line-height: 1.2;
  }

  .lsc-blemish-grid__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .lsc-blemish-grid__card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 12px;
    padding: 1.5rem 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    cursor: pointer;
  }

  .lsc-blemish-grid__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: var(--gold, #C4A97D);
  }

  .lsc-blemish-grid__card-content {
    flex: 1;
    min-width: 0;
  }

  .lsc-blemish-grid__card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--charcoal, #2C2C2C);
    margin: 0 0 0.35rem 0;
    line-height: 1.25;
  }

  .lsc-blemish-grid__card-desc {
    font-family: 'Outfit', sans-serif;
    font-size: 0.78rem;
    font-weight: 300;
    color: var(--dark-taupe, #6B5E54);
    line-height: 1.5;
    margin: 0;
  }

  .lsc-blemish-grid__card-arrow {
    flex-shrink: 0;
    font-size: 1.1rem;
    color: var(--gold, #C4A97D);
    transition: transform 0.25s ease;
  }

  .lsc-blemish-grid__card:hover .lsc-blemish-grid__card-arrow {
    transform: translateX(3px);
  }

  /* ── "Not Sure" card accent styling ── */
  .lsc-blemish-grid__card--unsure {
    background: transparent;
    border: 2px dashed var(--gold, #C4A97D);
    grid-column: 1 / -1;
    max-width: 540px;
    margin: 0.5rem auto 0;
    justify-self: center;
    width: 100%;
  }

  .lsc-blemish-grid__card--unsure:hover {
    background: rgba(196, 169, 125, 0.06);
    border-style: solid;
  }

  .lsc-blemish-grid__card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--gold, #C4A97D);
    color: #fff;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    flex-shrink: 0;
  }

  /* ── Mobile: 2 columns ── */
  @media screen and (max-width: 768px) {
    .lsc-blemish-grid {
      padding: 3.5rem 5%;
    }

    .lsc-blemish-grid__cards {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .lsc-blemish-grid__card {
      padding: 1.15rem 1rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .lsc-blemish-grid__card-arrow {
      align-self: flex-end;
    }

    .lsc-blemish-grid__card-title {
      font-size: 1.05rem;
    }

    .lsc-blemish-grid__card-desc {
      font-size: 0.72rem;
    }

    .lsc-blemish-grid__card--unsure {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      max-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Blemish Type Grid",
  "settings": [],
  "presets": [
    {
      "name": "Blemish Type Grid"
    }
  ]
}
{% endschema %}
