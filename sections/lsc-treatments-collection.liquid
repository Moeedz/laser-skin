<!-- ════════════════════════════════════════════════
     INTERSECTION OBSERVER — Staggered Scroll Reveal
     ════════════════════════════════════════════════ -->
<script>
  (function() {
    var cards = document.querySelectorAll('.lsc-tc__card');

    if (!('IntersectionObserver' in window)) {
      // No IO support — just show all cards immediately
      return;
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('lsc-tc--visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0,
      rootMargin: '0px 0px 0px 0px'
    });

    cards.forEach(function(card) {
      card.classList.add('lsc-tc--ready');
      observer.observe(card);
    });

    // Fallback: reveal any cards still hidden after 800ms
    setTimeout(function() {
      document.querySelectorAll('.lsc-tc__card.lsc-tc--ready:not(.lsc-tc--visible)').forEach(function(card) {
        card.classList.add('lsc-tc--visible');
      });
    }, 800);
  })();
</script>

