{%- comment -%}
  LSC "What It Treats" Section
  Visual grid showing conditions/concerns a treatment addresses.
  Data: section blocks (priority) or product.metafields.custom.what_it_treats (JSON array fallback).
{%- endcomment -%}

{%- liquid
  assign use_blocks = false
  assign use_metafield = false
  if section.blocks.size > 0
    assign use_blocks = true
  elsif product.metafields.custom.what_it_treats != blank
    assign use_metafield = true
  endif
-%}

{%- if use_blocks or use_metafield -%}
<section class="lsc-what-it-treats">
  <div class="lsc-what-it-treats__header">
    <span class="lsc-what-it-treats__eyebrow">{{ section.settings.eyebrow | default: 'IDEAL FOR' }}</span>
    <h2 class="lsc-what-it-treats__heading">{{ section.settings.heading | default: 'What It Treats' }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="lsc-what-it-treats__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="lsc-what-it-treats__grid">
    {%- if use_blocks -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'condition' -%}
          <div class="lsc-what-it-treats__card" {{ block.shopify_attributes }}>
            <span class="lsc-what-it-treats__icon">{{ block.settings.icon }}</span>
            <h3 class="lsc-what-it-treats__title">{{ block.settings.title }}</h3>
            {%- if block.settings.description != blank -%}
              <p class="lsc-what-it-treats__desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- elsif use_metafield -%}
      {%- assign conditions = product.metafields.custom.what_it_treats.value -%}
      {%- for item in conditions -%}
        <div class="lsc-what-it-treats__card">
          {%- if item.icon != blank -%}
            <span class="lsc-what-it-treats__icon">{{ item.icon }}</span>
          {%- endif -%}
          <h3 class="lsc-what-it-treats__title">{{ item.title }}</h3>
          {%- if item.description != blank -%}
            <p class="lsc-what-it-treats__desc">{{ item.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>
{%- endif -%}

<style>
  .lsc-what-it-treats {
    background: var(--warm-white, #FAF8F5);
    padding: 5rem 6%;
  }

  .lsc-what-it-treats__header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .lsc-what-it-treats__eyebrow {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold, #C4A97D);
    margin-bottom: 0.75rem;
  }

  .lsc-what-it-treats__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 2.5vw, 2.4rem);
    font-weight: 400;
    color: var(--charcoal, #2C2C2C);
    margin: 0;
    line-height: 1.2;
  }

  .lsc-what-it-treats__subheading {
    font-family: 'Outfit', sans-serif;
    font-size: 0.88rem;
    font-weight: 300;
    color: var(--dark-taupe, #6B5E54);
    line-height: 1.7;
    margin: 1rem 0 0 0;
  }

  .lsc-what-it-treats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 960px;
    margin: 0 auto;
  }

  .lsc-what-it-treats__card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.05);
    padding: 2rem 1.5rem;
    text-align: center;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .lsc-what-it-treats__card:hover {
    border-color: var(--gold, #C4A97D);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .lsc-what-it-treats__icon {
    display: block;
    font-size: 1.6rem;
    margin-bottom: 0.75rem;
    line-height: 1;
  }

  .lsc-what-it-treats__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--charcoal, #2C2C2C);
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
  }

  .lsc-what-it-treats__desc {
    font-family: 'Outfit', sans-serif;
    font-size: 0.78rem;
    font-weight: 300;
    color: var(--dark-taupe, #6B5E54);
    line-height: 1.65;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .lsc-what-it-treats {
      padding: 3.5rem 6%;
    }

    .lsc-what-it-treats__grid {
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .lsc-what-it-treats__card {
      padding: 1.5rem 1.25rem;
    }
  }

  @media screen and (max-width: 480px) {
    .lsc-what-it-treats__grid {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }

    .lsc-what-it-treats__card {
      padding: 1.25rem 1rem;
    }

    .lsc-what-it-treats__icon {
      font-size: 1.3rem;
    }

    .lsc-what-it-treats__title {
      font-size: 0.95rem;
    }
  }
</style>

{% schema %}
{
  "name": "What It Treats",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "IDEAL FOR"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What It Treats"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading (optional)"
    }
  ],
  "blocks": [
    {
      "type": "condition",
      "name": "Condition",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or symbol)",
          "info": "Use an emoji like ✦ or paste an icon character."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Condition Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short Description (optional)"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "What It Treats"
    }
  ]
}
{% endschema %}
