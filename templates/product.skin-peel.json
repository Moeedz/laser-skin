    "ss_image_with_text_12_gUF6fh": {
      "type": "ss-image-with-text-12",
      "blocks": {
        "slide_4jhyPz": {
          "type": "slide",
          "settings": {
            "heading": "<h3><strong>Advanced Skin Renewal for Smoother, Firmer, More Youthful Skin</strong></h3>",
            "text": "<p>CO2 Laser Resurfacing is one of the most effective treatments available for advanced skin renewal.</p><p>It uses concentrated beams of carbon dioxide laser energy to remove damaged skin cells, stimulate collagen production, and trigger the body’s natural healing response.</p><p>The result is smoother, tighter, and more even skin with a visible reduction in fine lines, pigmentation, scarring, and sun damage.</p><p>At Laser Skin Clinics, we offer both <strong>ablative</strong> and <strong>non-ablative</strong> CO2 laser resurfacing.</p><p>Ablative treatments precisely remove the outermost layers of the skin to deliver dramatic results for deeper wrinkles, texture irregularities, and scars.</p><p>Non-ablative treatments gently heat the deeper layers of the skin without removing surface tissue, ideal for those seeking noticeable rejuvenation with minimal downtime.</p><p>Your practitioner will advise which approach best suits your skin type, goals, and recovery preferences.<br/></p>",
            "button": "Book Online",
            "button_url": "https://partner.pabau.com/online-bookings/laser-skin-clinics?&category=93157&services=3552096&location=4546",
