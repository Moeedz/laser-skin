{% comment %}
  LSC What's Included Section
  Shows 3 treatment cards side by side for bundle/package pages.
  Content populated via blocks in the template JSON.
{% endcomment %}

<section class="lsc-whats-included">
  <div class="lsc-whats-included__header">
    <span class="lsc-whats-included__eyebrow">{{ section.settings.eyebrow | default: "YOUR PACKAGE" }}</span>
    <h2 class="lsc-whats-included__heading">{{ section.settings.heading | default: "What's Included" }}</h2>
  </div>

  <div class="lsc-whats-included__grid">
    {%- for block in section.blocks -%}
    <div class="lsc-whats-included__card" {{ block.shopify_attributes }}>
      <div class="lsc-whats-included__card-number">{{ forloop.index }}</div>
      <h3 class="lsc-whats-included__card-title">{{ block.settings.title }}</h3>
      <p class="lsc-whats-included__card-description">{{ block.settings.description }}</p>
      {%- if block.settings.value != blank -%}
        <span class="lsc-whats-included__card-value">{{ block.settings.value }}</span>
      {%- endif -%}
      {%- if block.settings.link != blank -%}
        <a href="{{ block.settings.link }}" class="lsc-whats-included__card-link">Learn more &rarr;</a>
      {%- endif -%}
    </div>
    {%- endfor -%}
  </div>
</section>

<style>
  .lsc-whats-included {
    padding: 5rem 6%;
    background: #fff;
  }

  .lsc-whats-included__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .lsc-whats-included__eyebrow {
    display: block;
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--taupe, #8B7E74);
    margin-bottom: 0.75rem;
  }

  .lsc-whats-included__heading {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 2.2rem;
    font-weight: 400;
    color: var(--charcoal, #2C2C2C);
    margin: 0;
  }

  .lsc-whats-included__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .lsc-whats-included__card {
    background: var(--cream, #F7F3EE);
    padding: 2rem;
    text-align: center;
    border: 1px solid rgba(0, 0, 0, 0.04);
  }

  .lsc-whats-included__card-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--charcoal, #2C2C2C);
    color: #fff;
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.82rem;
    font-weight: 500;
    margin-bottom: 1.2rem;
  }

  .lsc-whats-included__card-title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--charcoal, #2C2C2C);
    margin: 0 0 0.8rem 0;
  }

  .lsc-whats-included__card-description {
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--dark-taupe, #6B5E54);
    line-height: 1.7;
    margin: 0 0 1rem 0;
  }

  .lsc-whats-included__card-value {
    display: block;
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--gold, #C4A87C);
    margin-bottom: 0.5rem;
  }

  .lsc-whats-included__card-link {
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--charcoal, #2C2C2C);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.3s;
  }

  .lsc-whats-included__card-link:hover {
    color: var(--gold, #C4A87C);
  }

  @media screen and (max-width: 768px) {
    .lsc-whats-included {
      padding: 3.5rem 6%;
    }

    .lsc-whats-included__grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }

    .lsc-whats-included__heading {
      font-size: 1.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "What's Included",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "YOUR PACKAGE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What's Included"
    }
  ],
  "blocks": [
    {
      "type": "treatment",
      "name": "Treatment",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Treatment Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value (e.g. 'Worth £60')"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link to treatment page"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What's Included"
    }
  ]
}
{% endschema %}
