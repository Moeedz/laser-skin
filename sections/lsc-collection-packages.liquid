      <div class="lsc-pkg__badge">Most Popular</div>
      <a href="/products/the-tighten-clean-glow-package" class="lsc-pkg__card-overlay-link" aria-label="View Tighten Clean and Glow package details"></a>
      <div class="lsc-pkg__card-image-wrap">
        {%- if pkg2_img -%}
