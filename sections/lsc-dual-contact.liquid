{% comment %}
  LSC Dual Contact Section
  Two-column contact section: WhatsApp CTA + Enquiry Form
  WhatsApp booking message: reads from product.metafields.custom.whatsapp_message first,
  then falls back to section.settings.whatsapp_message.
  On product pages, a second outlined "Want more info" button is shown below the primary.
{% endcomment %}
{%- if section.settings.whatsapp_message_override != blank -%}
  {%- assign wa_msg = section.settings.whatsapp_message_override -%}
{%- else -%}
  {%- assign wa_msg = product.metafields.custom.whatsapp_message | default: section.settings.whatsapp_message | default: "Hi! I'd like to book an appointment please." -%}
{%- endif -%}
{%- if product -%}
  {%- assign wa_info_msg = "Hi! I'd like to find out more about " | append: product.title | append: " please." -%}
{%- elsif section.settings.whatsapp_info_message != blank -%}
  {%- assign wa_info_msg = section.settings.whatsapp_info_message -%}
{%- endif -%}

<section class="lsc-dual-contact" id="lsc-contact">
  <div class="lsc-dual-contact__header">
    <span class="lsc-dual-contact__eyebrow">YOUR NEXT STEP</span>
    <h2 class="lsc-dual-contact__heading">Get in Touch</h2>
  </div>

  <div class="lsc-dual-contact__grid">
    <!-- Left Column: WhatsApp CTA -->
    <div class="lsc-dual-contact__card">
      <h3 class="lsc-dual-contact__card-heading">Message Us on WhatsApp</h3>
      <p class="lsc-dual-contact__card-description">
        Get a response within minutes. Send us a message and we'll help you book the right treatment.
      </p>
      <a
        href="https://wa.me/447798983387?text={{ wa_msg | url_encode }}"
        class="lsc-dual-contact__whatsapp-btn"
        target="_blank"
        rel="noopener noreferrer"
        data-wa-type="ready_to_book"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Ready to Book
      </a>
      {%- if wa_info_msg != blank -%}
      <a
        href="https://wa.me/447798983387?text={{ wa_info_msg | url_encode }}"
        class="lsc-dual-contact__whatsapp-btn lsc-dual-contact__whatsapp-btn--outline"
        target="_blank"
        rel="noopener noreferrer"
        data-wa-type="have_a_question"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        I Have a Question
      </a>
      {%- endif -%}
      <p class="lsc-dual-contact__response-time">Usually responds within minutes</p>
      <p class="lsc-dual-contact__alt-contact">Prefer email? <a href="mailto:info@laserskinclinics.co.uk">info@laserskinclinics.co.uk</a></p>

    </div>

    <!-- Right Column: Enquiry Form -->
    <div class="lsc-dual-contact__card">
      <h3 class="lsc-dual-contact__card-heading">Send an Enquiry</h3>
      {% form 'contact', id: 'contact_form' %}
        <input type="hidden" name="contact[subject]" value="Website Enquiry">
        {%- if product -%}
        <input type="hidden" name="contact[treatment]" value="{{ product.title }}">
        {%- endif -%}

        <div class="lsc-dual-contact__field">
          <input
            type="text"
            name="contact[name]"
            placeholder="Your name"
            required
            class="lsc-dual-contact__input"
          >
        </div>

        <div class="lsc-dual-contact__field">
          <input
            type="email"
            name="contact[email]"
            placeholder="Your email"
            required
            class="lsc-dual-contact__input"
          >
        </div>

        <div class="lsc-dual-contact__field">
          <input
            type="tel"
            name="contact[phone]"
            placeholder="Your phone number (optional)"
            class="lsc-dual-contact__input"
          >
        </div>

        <div class="lsc-dual-contact__field">
          <select name="contact[how_can_we_help]" required class="lsc-dual-contact__input lsc-dual-contact__select">
            <option value="" disabled selected>How can we help?</option>
            <option value="I would like to book a treatment">I would like to book a treatment</option>
            <option value="I would like to book an appointment">I would like to book an appointment</option>
            <option value="I have a question">I have a question</option>
            <option value="I would like to discuss pricing or finance">I would like to discuss pricing or finance</option>
          </select>
        </div>

        <div class="lsc-dual-contact__field">
          <select name="contact[preferred_contact]" required class="lsc-dual-contact__input lsc-dual-contact__select">
            <option value="" disabled selected>How would you prefer us to contact you?</option>
            <option value="Email">Email</option>
            <option value="Phone call">Phone call</option>
            <option value="WhatsApp">WhatsApp</option>
          </select>
        </div>

        <div class="lsc-dual-contact__field">
          <textarea
            name="contact[body]"
            placeholder="Your message (optional)"
            rows="4"
            class="lsc-dual-contact__input lsc-dual-contact__textarea"
          ></textarea>
        </div>

        <button type="submit" class="lsc-dual-contact__submit-btn btn-primary">
          Send Message
        </button>
      {% endform %}
    </div>
  </div>
</section>

<style>
  .lsc-dual-contact {
    background: var(--cream, #F7F3EE);
    padding: 5rem 6%;
  }

  .lsc-dual-contact__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .lsc-dual-contact__eyebrow {
    display: block;
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--taupe, #8B7E74);
    margin-bottom: 0.75rem;
  }

  .lsc-dual-contact__heading {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 2.2rem;
    font-weight: 400;
    color: var(--charcoal, #2C2C2C);
    margin: 0;
  }

  .lsc-dual-contact__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 900px;
    margin: 0 auto;
    gap: 3rem;
  }

  .lsc-dual-contact__card {
    background: #fff;
    padding: 2.5rem;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .lsc-dual-contact__card-heading {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--charcoal, #2C2C2C);
    margin: 0 0 1rem 0;
  }

  .lsc-dual-contact__card-description {
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--dark-taupe, #6B5E54);
    line-height: 1.7;
    margin: 0 0 1.5rem 0;
  }

  .lsc-dual-contact__whatsapp-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.9rem 1.5rem;
    background: #25D366;
    color: #fff;
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.88rem;
    font-weight: 500;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s ease;
    box-sizing: border-box;
  }

  .lsc-dual-contact__whatsapp-btn:hover {
    background: #20bd5a;
    transform: translateY(-1px);
  }

  .lsc-dual-contact__whatsapp-btn + .lsc-dual-contact__whatsapp-btn {
    margin-top: 0.75rem;
  }

  .lsc-dual-contact__whatsapp-btn--outline {
    background: transparent;
    border: 1.5px solid #25D366;
    color: #1a9e4e;
  }

  .lsc-dual-contact__whatsapp-btn--outline:hover {
    background: #f0fdf4;
    border-color: #20bd5a;
    color: #177a3c;
    transform: translateY(-1px);
  }

  .lsc-dual-contact__whatsapp-btn svg {
    flex-shrink: 0;
  }

  .lsc-dual-contact__response-time {
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.72rem;
    color: var(--taupe, #8B7E74);
    text-align: center;
    margin: 0.75rem 0 0 0;
  }

  .lsc-dual-contact__alt-contact {
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.7rem;
    color: var(--taupe, #B8A99A);
    text-align: center;
    margin: 0.5rem 0 0 0;
    line-height: 1.6;
  }

  .lsc-dual-contact__alt-contact a {
    color: inherit;
    text-decoration: none;
  }

  .lsc-dual-contact__alt-contact a:hover {
    color: var(--charcoal, #2C2C2C);
  }

  .lsc-dual-contact__field {
    margin-bottom: 1rem;
  }

  .lsc-dual-contact__input {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1px solid var(--sand, #D6CEC4);
    border-radius: 0;
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.85rem;
    color: var(--charcoal, #2C2C2C);
    background: #fff;
    outline: none;
    transition: border-color 0.3s ease;
    box-sizing: border-box;
    -webkit-appearance: none;
    appearance: none;
  }

  .lsc-dual-contact__input::placeholder {
    color: var(--taupe, #8B7E74);
  }

  .lsc-dual-contact__input:focus {
    border-color: var(--gold, #C4A87C);
  }

  .lsc-dual-contact__textarea {
    resize: vertical;
    min-height: 100px;
  }

  .lsc-dual-contact__select {
    cursor: pointer;
    color: var(--taupe, #8B7E74);
  }

  .lsc-dual-contact__select:valid {
    color: var(--charcoal, #2C2C2C);
  }

  .lsc-dual-contact__submit-btn {
    display: block;
    width: 100%;
    padding: 0.9rem 1.5rem;
    background: var(--charcoal, #2C2C2C);
    color: var(--warm-white, #FAF8F5);
    font-family: var(--font-body, 'Outfit', sans-serif);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .lsc-dual-contact__submit-btn:hover {
    background: var(--gold, #C4A87C);
  }

  @media screen and (max-width: 768px) {
    .lsc-dual-contact {
      padding: 3.5rem 6%;
    }

    .lsc-dual-contact__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .lsc-dual-contact__heading {
      font-size: 1.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "Dual Contact",
  "settings": [
    {
      "type": "text",
      "id": "whatsapp_message_override",
      "label": "WhatsApp Message Override",
      "info": "Overrides the metafield whatsapp_message. Leave blank for default."
    },
    {
      "type": "text",
      "id": "whatsapp_message",
      "label": "WhatsApp Pre-filled Message",
      "default": "Hi! I'd like to book an appointment please."
    },
    {
      "type": "text",
      "id": "whatsapp_info_message",
      "label": "WhatsApp Info Message (optional second button)",
      "info": "If set, shows a second outlined 'I Have a Question' button. Leave blank for single button. On product pages this auto-populates from the product title."
    }
  ],
  "presets": [
    {
      "name": "Dual Contact"
    }
  ]
}
{% endschema %}
