{% comment %}
  LSC Treatments Collection Section
  Full treatments page with grouped sections, jump links, and staggered scroll reveal.
{% endcomment %}

{{ 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Outfit:wght@300;400;500&display=swap' | stylesheet_tag }}

<style>
  :root {
    --gold: #C4A97D;
    --gold-light: #D4BE9A;
    --deep: #1A1714;
    --charcoal: #2C2824;
    --cream: #F7F3EE;
    --warm-white: #FAF8F5;
    --dark-taupe: #6B5E53;
    --sand: #D6CEC4;
  }

  /* ── Dark Header ── */
  .lsc-tc__header {
    background: var(--charcoal);
    padding: 8rem 6% 3rem;
    text-align: center;
  }

  .lsc-tc__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 1rem;
  }

  .lsc-tc__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 300;
    color: #ffffff;
    line-height: 1.15;
    margin: 0 0 2.2rem;
  }

  /* ── Jump Links ── */
  .lsc-tc__jump-nav {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    padding-bottom: 0.5rem;
  }

  .lsc-tc__jump-link {
    font-family: 'Outfit', sans-serif;
    font-size: 0.73rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.6);
    padding: 0.5rem 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .lsc-tc__jump-link:hover {
    color: #ffffff;
    border-color: #ffffff;
  }

  /* ── Treatment Group ── */
  .lsc-tc__group {
    padding: 5rem 6%;
    scroll-margin-top: 2rem;
  }

  .lsc-tc__group--warm-white {
    background: var(--warm-white);
  }

  .lsc-tc__group--cream {
    background: var(--cream);
  }

  .lsc-tc__group-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .lsc-tc__group-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .lsc-tc__group-eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 0.6rem;
  }

  .lsc-tc__group-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--deep);
    margin: 0;
    line-height: 1.25;
  }

  /* ── Card Grid ── */
  .lsc-tc__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── Treatment Card ── */
  .lsc-tc__card {
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.05);
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .lsc-tc__card:hover {
    border-color: var(--gold);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .lsc-tc__card-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #e8e2da;
  }

  .lsc-tc__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .lsc-tc__card:hover .lsc-tc__card-image {
    transform: scale(1.03);
  }

  .lsc-tc__card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e2da;
  }

  .lsc-tc__card-placeholder svg {
    width: 40px;
    height: 40px;
    stroke: #c4b9ab;
    fill: none;
    stroke-width: 1;
  }

  .lsc-tc__card-content {
    padding: 1.5rem 1.5rem 1.8rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .lsc-tc__card-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--deep);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .lsc-tc__card-desc {
    font-family: 'Outfit', sans-serif;
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--dark-taupe);
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .lsc-tc__card-link {
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    margin-top: auto;
    padding-top: 1rem;
    transition: color 0.3s ease;
    display: inline-block;
  }

  .lsc-tc__card:hover .lsc-tc__card-link {
    color: var(--deep);
  }

  /* ── Staggered Scroll Reveal ── */
  @keyframes lscTcReveal {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Cards only hidden if JS is running (progressive enhancement) */
  .lsc-tc__card.lsc-tc--ready {
    opacity: 0;
  }

  .lsc-tc__card.lsc-tc--visible {
    animation: lscTcReveal 0.6s ease-out forwards;
  }

  /* ── Responsive: Tablet ── */
  @media screen and (max-width: 900px) {
    .lsc-tc__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .lsc-tc__group {
      padding: 4rem 6%;
    }
  }

  /* ── Responsive: Mobile ── */
  @media screen and (max-width: 580px) {
    .lsc-tc__header {
      padding: 7rem 5% 2.5rem;
    }

    .lsc-tc__grid {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .lsc-tc__group {
      padding: 3rem 5%;
    }

    .lsc-tc__jump-nav {
      justify-content: flex-start;
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 0.8rem;
    }

    .lsc-tc__jump-nav::-webkit-scrollbar {
      display: none;
    }

    .lsc-tc__jump-link {
      white-space: nowrap;
      flex-shrink: 0;
    }
  }
</style>

<!-- ════════════════════════════════════════════════
     DARK HEADER + JUMP LINKS
     ════════════════════════════════════════════════ -->
<section class="lsc-tc__header">
  <p class="lsc-tc__eyebrow">ALL TREATMENTS</p>
  <h1 class="lsc-tc__heading">Our Treatments</h1>

  <nav class="lsc-tc__jump-nav" aria-label="Treatment categories">
    <a href="#laser" class="lsc-tc__jump-link">Laser</a>
    <a href="#injectables" class="lsc-tc__jump-link">Injectables</a>
    <a href="#skin-renewal" class="lsc-tc__jump-link">Skin Renewal</a>
