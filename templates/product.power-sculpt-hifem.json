    "faq": {
      "type": "lsc-faq",
      "blocks": {
        "faq_1": {
          "type": "faq",
          "settings": {
            "question": "What is non-surgical body sculpting?",
            "answer": "<p>Non-surgical body sculpting is a treatment designed to strengthen and tone targeted muscle groups using advanced electromagnetic stimulation technology.</p><p>It is delivered without needles or surgery and is structured as a progressive treatment course.</p>"
          }
        },
        "faq_2": {
          "type": "faq",
          "settings": {
            "question": "How does non-surgical body sculpting work?",
            "answer": "<p>The treatment uses controlled electromagnetic energy to trigger repeated, high-intensity muscle contractions in targeted areas.</p><p>These contractions engage muscle fibres beyond voluntary exercise levels, supporting muscle strengthening and improved definition over time.</p>"
          }
        },
        "faq_3": {
          "type": "faq",
          "settings": {
            "question": "Does it reduce fat?",
            "answer": "<p>Non-surgical body sculpting is primarily designed to improve muscle tone and definition.</p><p>Some patients may notice contour improvements in treated areas; however, it is not a weight loss treatment.</p><p>It works best for body shaping rather than overall fat reduction.</p>"
          }
        },
        "faq_4": {
          "type": "faq",
          "settings": {
            "question": "Is this a replacement for exercise?",
            "answer": "<p>No.</p><p>Non-surgical body sculpting supports muscle activation and tone but does not replace regular exercise, nutrition, or a healthy lifestyle.</p><p>It is most effective as part of an overall body maintenance plan.</p>"
          }
        },
        "faq_5": {
          "type": "faq",
          "settings": {
            "question": "Does the treatment hurt?",
            "answer": "<p>Most patients describe the sensation as intense but tolerable muscle contractions.</p><p>You will feel your muscles working strongly. The intensity can be adjusted to suit comfort levels.</p>"
          }
        },
        "faq_6": {
          "type": "faq",
          "settings": {
            "question": "Is there any downtime?",
            "answer": "<p>No.</p><p>You can return to normal activities immediately after treatment. Mild muscle soreness similar to a workout may occur.</p>"
          }
        },
        "faq_7": {
          "type": "faq",
          "settings": {
            "question": "How many sessions do I need?",
            "answer": "<p>A course of 4–6 sessions is typically recommended for visible improvement.</p><p>Treatment plans are structured to allow progressive muscle adaptation over time.</p>"
          }
        },
        "faq_8": {
          "type": "faq",
          "settings": {
            "question": "When will I see results?",
            "answer": "<p>Some patients feel increased muscle activation immediately.</p><p>Visible contour improvement typically develops gradually over several weeks as muscle tone improves.</p>"
          }
        },
        "faq_9": {
          "type": "faq",
          "settings": {
            "question": "Is non-surgical body sculpting suitable for everyone?",
            "answer": "<p>It may not be suitable if you:</p><p>• Have a pacemaker or implanted electronic device</p><p>• Are pregnant</p><p>• Have certain medical conditions</p><p>• Have metal implants in the treatment area</p><p>A medical assessment will determine suitability.</p>"
          }
        },
        "faq_10": {
          "type": "faq",
          "settings": {
            "question": "Can it help after pregnancy?",
            "answer": "<p>Non-surgical body sculpting may support abdominal muscle strengthening after pregnancy, particularly for mild muscle laxity.</p><p>However, it is not a medical treatment for diastasis recti and suitability must be assessed individually.</p>"
          }
        },
        "faq_11": {
          "type": "faq",
          "settings": {
            "question": "How long is a session?",
            "answer": "<p>Sessions typically last around 30 minutes depending on the treatment area.</p>"
          }
        },
        "faq_12": {
          "type": "faq",
          "settings": {
            "question": "What payment options do you offer?",
            "answer": "<p>We offer flexible payment options to make your treatment as convenient as possible. You can choose to pay per single session or pay in full for a course of treatments for better overall value. We accept card, cash, and bank transfer in clinic.</p><p>For added flexibility, we also offer 0% finance through Klarna, allowing you to spread the cost into manageable instalments with a range of payment options available, subject to eligibility.</p><p>If you’re unsure which option is best for you, our team will be happy to guide you during your consultation.</p>"
          }
        },
        "faq_13": {
          "type": "faq",
          "settings": {
            "question": "Who is Power Sculpt suitable for?",
            "answer": "<p>It’s ideal for men and women looking to tone, lift or define specific body areas without surgery.</p><p>Whether you want to enhance your workouts, sculpt your core, or lift and firm the glutes, Power Sculpt can help achieve those goals safely and effectively.</p>"
          }
        },
        "faq_14": {
          "type": "faq",
          "settings": {
            "question": "What is your cancellation policy?",
            "answer": "<p>Cancellations up to 24 hours before your appointment will receive a full refund or can be rescheduled.<br/><br/>Any cancellations on the day can be rescheduled but will not be refunded.<br/><br/>If you do not show to your appointment you will not receive a refund or a reschedule. Please note that we offer email and text appointment reminders right up until 24 hours before your appointment.</p>"
          }
        },
        "faq_15": {
          "type": "faq",
          "settings": {
            "question": "I would like to speak to someone before I book my treatment, how is best to do this?",
            "answer": "<p>If you would like to speak to someone please do one of the below.<br/><br/>- Use the enquiry button.<br/><br/>- Contact us via email at info@laserskinclinics.co.uk<br/><br/>- Call us during opening hours on 01902 256667<br/><br/>- Send us a WhatsApp by clicking the WhatsApp button on the website.</p>"
          }
        },
        "faq_16": {
          "type": "faq",
          "settings": {
            "question": "Does it hurt?",
            "answer": "<p>No, Power Sculpt is completely non-invasive and pain-free.</p><p>You’ll feel strong but comfortable muscle contractions during the treatment, followed by a slight tingling or tightness. There’s no discomfort and no recovery period needed.</p>"
          }
        },
        "faq_17": {
          "type": "faq",
          "settings": {
            "question": "How soon will I see results?",
            "answer": "<p>Most clients start to notice increased tone and firmness after two or three sessions, with full results developing over the next few weeks as the muscles strengthen and fat cells are metabolised.</p>"
          }
        },
        "faq_18": {
          "type": "faq",
          "settings": {
            "question": "How many sessions will I need?",
            "answer": "<p>We recommend a course of 6 sessions once every 1/2 weeks to see optimal results.</p>"
          }
        }
      },
